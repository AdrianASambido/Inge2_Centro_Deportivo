@page "/restablecer-contrasenia"
@inject IUsuarioRepositorio UsuarioRepositorio
@rendermode InteractiveServer
@inject NavigationManager Navegador
@inject RestablecerContraseniaUseCase RestablecerContraseñaUseCase

<PageTitle>Restablecer Contraseña</PageTitle>

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card-shadow p-6" style="width: 100%; max-width: 400px;">
        <h3 class="text-center mb-4">Restablecer Contraseña</h3>

        <div class="mb-4">
            <label class="form-label">Nueva contraseña</label>
            <input placeholder="********" @bind="nueva1" class="form-control" type="password" autocomplete="new-password" />
        </div>

        <div class="mb-4">
            <label class="form-label">Repita la contraseña</label>
            <input placeholder="********" @bind="nueva2" class="form-control" type="password" autocomplete="new-password" />
        </div>

        <div class="d-grid gap-2 mb-3 mt-2">
            <button class="btn btn-outline-primary mb-2" @onclick="Redirigir">Confirmar</button>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger mt-2 text-center">@error</div>
        }
    </div>
</div>


@code {
    string error = "";
    string nueva1 = "";
    string nueva2 = "";

    [Parameter]
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(Token))
        {
            var uri = Navegador.ToAbsoluteUri(Navegador.Uri);
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
            
            if (query.TryGetValue("token", out var tokenValue))
            {
                Token = tokenValue;
            }
        }
    }

    async Task Redirigir()
    {
        error = "";
        try
        {
            if (string.IsNullOrWhiteSpace(nueva1) || string.IsNullOrWhiteSpace(nueva2))
            {
                error = "Debe completar ambos campos.";
                return;
            }

            if (nueva1 != nueva2)
            {
                error = "Las contraseñas no coinciden.";
                return;
            }

            if (string.IsNullOrEmpty(Token))
            {
                error = "El link de recuperación no es válido o ha expirado.";
                return;
            }

            await RestablecerContraseñaUseCase.Ejecutar(nueva1,Token);

            nueva1 = "";
            nueva2 = "";
            Navegador.NavigateTo("/Login");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }
}
}
