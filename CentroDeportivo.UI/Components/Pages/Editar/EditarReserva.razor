@inject NavigationManager Navegador

<PageTitle>Editar Reserva</PageTitle>

<h3>Datos de la Reserva</h3>

@if (reserva == null)
{
    <div class="alert alert-warning">No se encontro la reserva solicitada.</div>
}
else
{
    <div class="card p-3 mb-3">
        <p><strong>Id:</strong> @reserva.Id</p>
        <p><strong>Usuario:</strong> @reserva.Id_Usuario</p>
        <p><strong>Turno:</strong> @reserva.Id_Turno</p>
        <p><strong>Estado:</strong> @reserva.Estado</p>
        <p><strong>Fecha de reserva:</strong> @reserva.FechaReserva</p>
    </div>
}

<button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert alert-danger">@mensaje</div>
}


