@page "/"
@inject NavigationManager Navigation

<PageTitle>Inicio - Centro Deportivo</PageTitle>

<section class="home-hero py-5 py-md-6">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-10">
                <div class="hero-card text-center shadow-lg">
                    <span class="badge rounded-pill text-bg-primary px-3 py-2 mb-3">
                        <i class="bi bi-lightning-charge-fill me-1"></i> Centro Deportivo
                    </span>
                    <h1 class="display-5 fw-bold mb-3">Bienvenido al Centro Deportivo</h1>
                    <p class="lead text-muted mb-4">
                        Gestiona reservas y actividades de forma simple, rapida y organizada.
                    </p>
                    <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center mb-4">
                        <button class="btn btn-primary btn-lg px-4" @onclick="IrAReservas">
                            <i class="bi bi-calendar-check me-2"></i>Realizar una reserva
                        </button>
                        <button class="btn btn-outline-primary btn-lg px-4" @onclick="IrAActividades">
                            <i class="bi bi-grid me-2"></i>Ver actividades
                        </button>
                    </div>

                    <div class="row g-3 text-start">
                        <div class="col-md-4">
                            <div class="feature-card h-100">
                                <i class="bi bi-stopwatch feature-icon"></i>
                                <h5 class="mt-3 mb-2">Reserva en minutos</h5>
                                <p class="mb-0 text-muted">Selecciona horario y actividad en pocos pasos.</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="feature-card h-100">
                                <i class="bi bi-people feature-icon"></i>
                                <h5 class="mt-3 mb-2">Gestion de socios</h5>
                                <p class="mb-0 text-muted">Mantiene la informacion de los socios siempre al dia.</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="feature-card h-100">
                                <i class="bi bi-graph-up-arrow feature-icon"></i>
                                <h5 class="mt-3 mb-2">Mejor organizacion</h5>
                                <p class="mb-0 text-muted">Visualiza disponibilidad y evita superposiciones.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private void IrAReservas()
    {
        Navigation.NavigateTo("reservas");
    }

    private void IrAActividades()
    {
        Navigation.NavigateTo("Actividades");
    }
}
