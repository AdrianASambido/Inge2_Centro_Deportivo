@page "/Actividades"
@rendermode InteractiveServer
@inject IActividadRepositorio RepositorioActividad
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador

<PageTitle>Actividades</PageTitle>

@if (!UsuarioSesion.EstaAutenticado())
{
    <p>No tenés acceso. <NavLink href="/Login">Iniciar sesión</NavLink></p>
}
else
{
    <h2>Actividades</h2>

    <p>Bienvenido, @UsuarioSesion.UsuarioActual!.Nombre</p>
    <button class="btn btn-danger" @onclick="CerrarSesion">Cerrar sesión</button>
    <button class="btn btn-success" @onclick="CrearActividad">Crear actividad</button>

    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Descripcion</th>
                <th>Precio</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in actividad)
            {
                <tr>
                    <td>@a.Id</td>
                    <td>@a.nombre</td>
                    <td>@a.descripcion</td>
                    <td>@a.precio</td>
                    <td>
                        <button class="btn btn-primary"
                                @onclick="() => Editar(a.Id)">
                            Editar
                        </button>

                        <button class="btn btn-danger"
                                @onclick="() => ConfirmarEliminacion(a.Id)">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>

    </table>

   
}

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert alert-danger">@mensaje</div>
}

@if (mostrarDialog)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                </div>
                <div class="modal-body">
                    <p>¿Estás seguro de que querés eliminar esta actividad?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => mostrarDialog = false">Cancelar</button>
                    <button class="btn btn-danger" @onclick="Eliminar">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
}

    
@code {

    string mensaje = "";
    bool mostrarDialog = false;
    int idAEliminar;
    void MostrarMensaje(string msj)
    {
        mensaje = msj;
    }


    List<Actividad> actividad = new List<Actividad>();
    
    protected override void OnInitialized()
    {
        actividad = ListarActividadesUseCase.Ejecutar()!;
    }
    void CerrarSesion()
    {
        UsuarioSesion.CerrarSesion();
        Navegador.NavigateTo("/Login", true);
    }

    void CrearActividad()
    {
        Navegador.NavigateTo("/crear-actividad", true);
    }

    public void Editar(int Id)
    {
        Navegador.NavigateTo($"/editar-actividad/{Id}");
    }

    void ConfirmarEliminacion(int Id)
    {
        idAEliminar = Id;
        mostrarDialog = true;
    }

    void Eliminar()
    {
        mostrarDialog = false;
        try
        {
            EliminarActividadUseCase.Ejecutar(idAEliminar, UsuarioSesion.UsuarioActual!.Id);
            actividad = ListarActividadesUseCase.Ejecutar()!;
            MostrarMensaje("Actividad eliminada correctamente.");
        }
        catch (Exception ex)
        {
            MostrarMensaje(ex.Message);
        }
        
    }
}
