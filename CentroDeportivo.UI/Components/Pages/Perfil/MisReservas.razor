@page "/MisReservas"
@rendermode InteractiveServer
@inject GenerarQrUseCase GenerarQRUseCase
@inject IReservaRepositorio ReservaRepositorio
@inject Sesion UsuarioSesion
@inject ListarReservasUseCase listarReservasUseCase
@inject CancelarReservaUseCase cancelarReservasUseCase
@inject NavigationManager Navigation
@inject CancelarReservaUseCase CancelarReservaCase

<PageTitle>Mis Reservas</PageTitle>

<div class="container-fluid p-0">
    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm">
            <h2 class="mb-1">Mis reservas</h2>

        
        <div class="table-responsive shadow-sm" style="background: white; border-radius: 8px;">

            @if (qrCode != null && qrCode.Length > 0)
            {
                <div class="card mb-4 shadow-sm" style="max-width: 300px; margin: auto;">
                    <div class="card-body text-center">
                        <h5 class="card-title">Tu Código QR</h5>
                        <img src="data:image/png;base64,@Convert.ToBase64String(qrCode)" class="img-fluid" alt="QR Asistencia" />
                        <p class="card-text small text-muted mt-2">Presentalo en la recepción para ingresar.</p>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => qrCode = Array.Empty<byte>()">Cerrar</button>
                    </div>
                </div>
            }

            @if (!UsuarioSesion.EstaAutenticado())
            {
                <p>No estás logueado.</p>
                <NavLink href="/login" class="btn btn-primary">Iniciar sesión</NavLink>
            }
            else if (reservas == null)
            {
                <p><em>Cargando reservas...</em></p>
            }
            else if (!reservas.Any())
            {
                <p>No tenés reservas registradas.</p>
            }
            else
            {
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Actividad</th>
                            <th>Fecha</th>
                            <th>Horario</th>
                            <th>Cancha</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in reservas)
                        {
                            <tr>
                                <td>@r.Turno?.Actividad?.Nombre</td>
                                <td>@r.Turno?.Fecha.ToShortDateString()</td>
                                <td>@r.Turno?.HoraInicio</td>
                                <td>@r.Turno?.Cancha.Numero</td>
                                <td>@r.Estado</td>

                                <td>
                                    <button class="btn btn-primary btn-sm me-1"
                                    @onclick="() => GenerarQr(r.Id)">
                                        <i class="bi bi-qr-code"></i> Generar QR
                                    </button>

                                    @if (reservaSeleccionadaId == r.Id && qrCode != null && qrCode.Length > 0)
                                    {
                                        <div class="card shadow-sm my-4 border-primary" style="max-width: 300px; position: absolute; z-index: 100;">
                                            <div class="card-header bg-primary text-white text-center">Tu código de acceso</div>
                                            <div class="card-body text-center bg-white">
                                                <img src="data:image/png;base64,@Convert.ToBase64String(qrCode)" alt="QR Reserva" style="width: 200px;" />
                                                <p class="small text-muted mt-2">Presentá este código al ingresar</p>
                                                <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarQr">Cerrar</button>
                                            </div>
                                        </div>
                                    }

                                    <button class="btn btn-danger btn-sm"
                                    @onclick="() => Cancelar(r.Id)">
                                        Cancelar
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
            
            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-info mt-3 shadow-sm">@error</div>
            }
    </div>
</div>
    
    
@code {
    List<Reserva>? reservas;
    private int? reservaSeleccionadaId; 
    private byte[] qrCode = Array.Empty<byte>();
    private string error = "";

    protected override async Task OnInitializedAsync()
    {
        error = "";
        try
        {
            reservas = (await listarReservasUseCase.Ejecutar(UsuarioSesion.UsuarioActual.Id)).ToList();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }

    }

    async Task GenerarQr(int reservaId)
    {
        error = "";
        if (reservaSeleccionadaId == reservaId)
        {
            CerrarQr();
            return;
        }

        try
        {
            qrCode = await GenerarQRUseCase.Ejecutar(reservaId);
            reservaSeleccionadaId = reservaId; 
        }
        catch (Exception ex)
        {
            error = ex.Message;
            StateHasChanged(); 
        }
    }

    void CerrarQr()
    {
        qrCode = Array.Empty<byte>();
        reservaSeleccionadaId = null;
    }

    async Task Cancelar(int idReserva)
    {
        try
        {
            
            var (conDevolucion, monto) = await cancelarReservasUseCase.Ejecutar(idReserva);

          
            error = conDevolucion
                ? $"Reserva cancelada exitosamente. Se ha generado una devolución de: ${monto}"
                : "Reserva cancelada exitosamente. No corresponde devolución.";

            
            if (UsuarioSesion.UsuarioActual != null)
            {
                var resultado = await listarReservasUseCase.Ejecutar(UsuarioSesion.UsuarioActual.Id);
                reservas = resultado.ToList();
            }
        }
        catch (Exception ex)
        {
            // Aquí capturamos tus "throw new Exception" del backend
            error = ex.Message;
        }
    }
}