@page "/MisReservas"
@rendermode InteractiveServer
@inject GenerarQrUseCase GenerarQRUseCase
@inject IReservaRepositorio repoReserva
@inject Sesion UsuarioSesion
@inject ListarReservasUseCase listarReservasUseCase
@inject CancelarReservaUseCase cancelarReservasUseCase
@inject CompletarPagoReservaOcasionalUseCase CompletarPagoReservaCase
@inject CancelarReservaAdelantadaUseCase CancelarReservaAdelantadaUseCase
@inject IniciarPagoListaEsperaUseCase IniciarPagoListaEsperaUseCase
@inject CrearReservaListaEsperaUseCase CrearReservaListaEsperaUseCase
@inject AbandonarListaEsperaUseCase AbandonarListaEsperaUseCase
@inject ConsultarListaEsperaUseCase ConsultarListaEsperaUseCase
@inject ListarReservasClasesMensualesUseCase ListarReservasClasesMensualesUseCase
@inject ConfirmarPagoRestanteReservaOcasionalUseCase ConfirmarPagoRestanteReservaOcasionalUseCase
@inject IniciarRenovarReservaAdelantadaUseCase IniciarRenovarReservaAdelantadaUseCase
@inject RenovarReservaAdelantadaUseCase RenovarReservaAdelantadaUseCase
@inject ObtenerDetalleRenovacionUseCase ObtenerDetalleRenovacionUseCase
@inject ObtenerUsuarioPorId ObtenerUsuarioPorId
@inject NavigationManager Navigation

<PageTitle>Mis Reservas</PageTitle>

<div class="container-fluid p-0">
    <div class="p-4 p-md-5 mb-4 bg-light rounded-3 shadow-sm">
        <h2 class="mb-3 fw-bold text-dark">Mis reservas</h2>

        @if (!UsuarioSesion.EstaAutenticado())
        {
            <div class="alert alert-warning border-0 shadow-sm d-flex align-items-center justify-content-between p-4" style="border-radius: 12px;">
                <div>
                    <h5 class="fw-bold text-warning-emphasis mb-1">Sesión no iniciada</h5>
                    <p class="mb-0 text-muted">Debes ingresar al sistema con tu cuenta para visualizar e interactuar con tus turnos.</p>
                </div>
                <NavLink href="/login" class="btn btn-warning fw-bold px-4 shadow-sm text-dark">Iniciar sesión</NavLink>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(error))
            {
                bool esExito = error.Contains("éxito", StringComparison.OrdinalIgnoreCase) ||
                               error.Contains("exitosamente", StringComparison.OrdinalIgnoreCase) ||
                               error.Contains("confirmada", StringComparison.OrdinalIgnoreCase);

                <div class="alert @(esExito ? "alert-success" : "alert-danger") border-0 shadow-sm mb-4" style="border-radius: 12px;">
                    <i class="bi @(esExito ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
                    @error
                </div>
            }

            <div class="d-flex gap-2 mb-4">
                <button class="btn py-2 px-3 fw-bold @(tipoFiltroActivo == 1 ? "btn-primary shadow" : "btn-outline-primary")"
                        style="border-radius: 10px;" @onclick="() => tipoFiltroActivo = 1">
                    <i class="bi bi-calendar-event me-2"></i>Reservas Ocasionales
                </button>
                <button class="btn py-2 px-3 fw-bold @(tipoFiltroActivo == 2 ? "btn-primary shadow" : "btn-outline-primary")"
                        style="border-radius: 10px;" @onclick="() => tipoFiltroActivo = 2">
                    <i class="bi bi-box-seam me-2"></i>Reservas Mensuales
                </button>
                <button class="btn py-2 px-3 fw-bold @(tipoFiltroActivo == 3 ? "btn-primary shadow" : "btn-outline-primary")"
                        style="border-radius: 10px;" @onclick="() => tipoFiltroActivo = 3">
                    <i class="bi bi-hourglass-split me-2"></i>Lista de Espera
                </button>
            </div>

            @if (tipoFiltroActivo == 1)
            {
                <div class="table-responsive shadow-sm border" style="background: white; border-radius: 12px;">
                    <table class="table table-hover align-middle m-0">
                        <thead class="table-light">
                            <tr class="text-uppercase small text-muted">
                                <th class="ps-3">Actividad</th>
                                <th>Fecha</th>
                                <th>Horario</th>
                                <th>Profesor</th>
                                <th>Precio Abonado</th>
                                <th>Estado</th>
                                <th class="text-end pe-3">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ObtenerReservasFiltradas().Any())
                            {
                                @foreach (var r in ObtenerReservasFiltradas())
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold text-dark">@r.Turno?.Actividad?.Nombre</td>
                                        <td>@r.Turno?.Fecha.ToShortDateString()</td>
                                        <td>@r.Turno?.HoraInicio.ToString("HH:mm") hs</td>
                                        <td>@r.Turno?.Profesor?.Nombre @r.Turno?.Profesor?.Apellido</td>
                                        <td><span class="badge bg-success-subtle text-success fs-6 px-2">$ @r.PrecioPagado</span></td>
                                        <td>
                                            <span class="badge @(r.Estado == EstadoReserva.Confirmado ? "bg-success" : "bg-warning text-dark")">
                                                @r.Estado
                                            </span>
                                        </td>
                                        <td class="text-end pe-3">
                                            @if (r.Estado == EstadoReserva.Reservado)
                                            {
                                                <button class="btn btn-success btn-sm me-1 fw-bold"
                                                        @onclick="() => PagarSaldoRestante(r.Id)">
                                                    <i class="bi bi-credit-card me-1"></i> Pagar Saldo (50%)
                                                </button>
                                            }

                                            <button class="btn btn-outline-primary btn-sm me-1"
                                                    @onclick="() => GenerarQr(r.Id)"
                                                    disabled="@(!PuedeGenerarQr(r))">
                                                <i class="bi bi-qr-code"></i> Generar QR
                                            </button>

                                            @if (reservaSeleccionadaId == r.Id && qrCode != null && qrCode.Length > 0)
                                            {
                                                <div class="card shadow border-primary my-2 text-center" style="max-width: 260px; position: absolute; right: 40px; z-index: 100; border-radius: 12px;">
                                                    <div class="card-header bg-primary text-white fw-bold small">Código de acceso</div>
                                                    <div class="card-body bg-white p-3">
                                                        <img src="data:image/png;base64,@Convert.ToBase64String(qrCode)" alt="QR Reserva" class="img-fluid mb-2" style="width: 160px;" />
                                                        <p class="small text-muted mb-2">Presentalo en mesa de entrada</p>
                                                        <button class="btn btn-outline-secondary btn-sm w-100" @onclick="CerrarQr">Cerrar</button>
                                                    </div>
                                                </div>
                                            }

                                            <button class="btn btn-danger btn-sm"
                                                    @onclick="() => Cancelar(r.Id)"
                                                    disabled="@(!PuedeCancelar(r))">
                                                Cancelar
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5 text-muted">
                                        <i class="bi bi-calendar-x fs-2 d-block mb-2"></i>
                                        No registra reservas ocasionales activas.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else if (tipoFiltroActivo == 2)
            {
                <div class="p-0">
                    @if (ObtenerPaquetesAdelantados().Any())
                    {
                        @foreach (var paquete in ObtenerPaquetesAdelantados())
                        {
                            <div class="card mb-3 border-primary shadow-sm" style="border-radius: 12px; overflow: hidden;">
                                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
                                    <div>
                                        <h5 class="mb-0 fw-bold">
                                            <i class="bi bi-box-seam me-2"></i> Paquete: @paquete.NombreActividad
                                        </h5>
                                        <small class="opacity-75">Código de compra: @paquete.CodigoPaquete.ToString().Substring(0, 8)...</small>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-light btn-sm text-primary fw-bold" style="border-radius: 6px;" @onclick="() => AlternarDetallePaquete(paquete.CodigoPaquete)">
                                            <i class="bi @(paqueteIdDesplegado == paquete.CodigoPaquete ? "bi-eye-slash-fill" : "bi-eye-fill") me-1"></i>
                                            @(paqueteIdDesplegado == paquete.CodigoPaquete ? "Ocultar turnos" : "Ver turnos")
                                        </button>

                                        <button class="btn btn-warning btn-sm fw-bold text-dark" style="border-radius: 6px;"
                                                disabled="@paquete.YaRenovo"
                                                @onclick="() => VerDetalleRenovacion(paquete.CodigoPaquete)">
                                            <i class="bi @(paquete.YaRenovo ? "bi-check-circle-fill" : "bi-arrow-repeat") me-1"></i>
                                            @(paquete.YaRenovo ? "Ya Renovado" : "Renovar")
                                        </button>
                                    </div>
                                </div>

                                @if (paqueteIdDesplegado == paquete.CodigoPaquete)
                                {
                                    <div class="card-body bg-light p-0">
                                        <div class="table-responsive">
                                            <table class="table table-sm table-hover m-0 bg-white align-middle">
                                                <thead class="table-secondary">
                                                    <tr class="small text-muted">
                                                        <th class="ps-3">Día / Fecha</th>
                                                        <th>Horario</th>
                                                        <th>Profesor</th>
                                                        <th>Precio</th>
                                                        <th>Estado</th>
                                                        <th class="text-end pe-3">Acciones</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var r in paquete.ReservasAsociadas.OrderBy(res => res.Turno?.Fecha))
                                                    {
                                                        <tr>
                                                            <td class="ps-3 fw-bold text-primary">@r.Turno?.Fecha.ToString("dddd dd/MM/yyyy")</td>
                                                            <td>@r.Turno?.HoraInicio.ToString("HH:mm") hs</td>
                                                            <td>@r.Turno?.Profesor?.Nombre @r.Turno?.Profesor?.Apellido</td>
                                                            <td>$ @r.PrecioPagado</td>
                                                            <td>
                                                                <span class="badge @(r.Estado == EstadoReserva.Confirmado ? "bg-success" : "bg-secondary")">
                                                                    @r.Estado
                                                                </span>
                                                            </td>
                                                            <td class="text-end pe-3 position-relative">
                                                                <button class="btn btn-outline-primary btn-sm me-1"
                                                                        @onclick="() => GenerarQr(r.Id)"
                                                                        disabled="@(!PuedeGenerarQr(r))">
                                                                    <i class="bi bi-qr-code"></i> QR
                                                                </button>

                                                                @if (reservaSeleccionadaId == r.Id && qrCode != null && qrCode.Length > 0)
                                                                {
                                                                    <div class="card shadow border-primary text-center p-2" style="position: absolute; right: 80px; top: -10px; z-index: 110; min-width: 180px; border-radius: 10px;">
                                                                        <img src="data:image/png;base64,@Convert.ToBase64String(qrCode)" alt="QR" class="img-fluid mx-auto mb-1" style="width: 120px;" />
                                                                        <button class="btn btn-outline-secondary btn-xs w-100" @onclick="CerrarQr">Cerrar</button>
                                                                    </div>
                                                                }

                                                                <button class="btn btn-danger btn-sm"
                                                                        @onclick="() => CancelarAdelantada(r.Id)"
                                                                        disabled="@(!PuedeCancelar(r))">
                                                                    Cancelar
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="card p-5 text-center text-muted bg-white shadow-sm border-0" style="border-radius: 12px;">
                            <i class="bi bi-box-seam fs-2 d-block mb-2"></i>
                            No registra pases mensuales o reservas adelantadas activas.
                        </div>
                    }
                </div>
            }
            else if (tipoFiltroActivo == 3)
            {
                <div class="table-responsive shadow-sm border" style="background: white; border-radius: 12px;">
                    @if (listaEspera != null && listaEspera.Any())
                    {
                        <table class="table table-hover align-middle m-0">
                            <thead class="table-light">
                                <tr class="text-uppercase small text-muted">
                                    <th class="ps-3">Actividad</th>
                                    <th>Fecha</th>
                                    <th>Horario</th>
                                    <th>Profesor</th>
                                    <th>Estado</th>
                                    <th class="text-end pe-3">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var inscripcion in listaEspera)
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold text-dark">@inscripcion.Turno?.Actividad?.Nombre</td>
                                        <td>@inscripcion.Turno?.Fecha.ToShortDateString()</td>
                                        <td>@inscripcion.Turno?.HoraInicio.ToString("HH:mm") hs</td>
                                        <td>@inscripcion.Turno?.Profesor?.Nombre @inscripcion.Turno?.Profesor?.Apellido</td>
                                        <td>
                                            <span class="badge @(inscripcion.Estado == EstadoListaEspera.Notificado ? "bg-success px-3 py-2" : "bg-warning text-dark")">
                                                @(inscripcion.Estado == EstadoListaEspera.Notificado ? "Lugar disponible" : "En espera")
                                            </span>
                                        </td>
                                        <td class="text-end pe-3">
                                            @if (inscripcion.Estado == EstadoListaEspera.Notificado)
                                            {
                                                <button class="btn btn-success btn-sm me-1 fw-bold"
                                                        @onclick="() => ReservarLugarLiberado(inscripcion.Id_Turno)">
                                                    <i class="bi bi-check-circle me-1"></i> Reservar Lugar
                                                </button>
                                            }
                                            <button class="btn btn-outline-danger btn-sm"
                                                    @onclick="() => AbandonarLista(inscripcion.Id_Turno)">
                                                <i class="bi bi-x-circle me-1"></i> Abandonar lista
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-hourglass-x fs-2 d-block mb-2"></i>
                            No registras turnos vigentes en lista de espera.
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@if (mostrarModalRenovacion && detalleRenovacion != null)
{
    <div class="modal show d-block animate-fade-in" tabindex="-1" style="background: rgba(0,0,0,0.55);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow" style="border-radius: 14px;">
                <div class="modal-header bg-light border-0 py-3">
                    <h5 class="modal-title fw-bold text-dark"><i class="bi bi-arrow-repeat text-warning me-2"></i>Detalle de renovación</h5>
                </div>
                <div class="modal-body p-4">
                    @if (!detalleRenovacion.TurnosDisponibles)
                    {
                        <div class="alert alert-warning border-0 shadow-sm mb-0">
                            No hay turnos cargados para <strong>@detalleRenovacion.NombreMes</strong> todavía.
                        </div>
                    }
                    else
                    {
                        @if (detalleRenovacion.YaRenovo)
                        {
                            <div class="alert alert-info shadow-sm d-flex align-items-center mb-3 border-0">
                                <i class="bi bi-info-circle-fill me-2 fs-5 text-info"></i>
                                <div>
                                    Usted ya renovó este paquete de clases para el mes de <strong>@detalleRenovacion.NombreMes</strong>.
                                </div>
                            </div>
                        }

                        <div class="list-group list-group-flush mb-2">
                            <div class="list-group-item px-0 d-flex justify-content-between">
                                <span class="text-muted">Período:</span>
                                <span class="fw-bold">@detalleRenovacion.NombreMes</span>
                            </div>
                            <div class="list-group-item px-0 d-flex justify-content-between">
                                <span class="text-muted">Cantidad de clases estimadas:</span>
                                <span class="fw-bold">@detalleRenovacion.CantidadClases</span>
                            </div>
                            <div class="list-group-item px-0 d-flex justify-content-between">
                                <span class="text-muted">Precio base unitario:</span>
                                <span class="fw-bold">$@detalleRenovacion.PrecioUnitario</span>
                            </div>
                        </div>

                        <div class="p-3 bg-light rounded-3 mt-3">
                            @if (detalleRenovacion.AplicaDescuento)
                            {
                                <p class="text-decoration-line-through text-muted small mb-1">
                                    Total sin beneficio: $@detalleRenovacion.PrecioTotal
                                </p>
                                <h5 class="text-success fw-bold mb-0 d-flex justify-content-between">
                                    <span>Total (20% OFF):</span>
                                    <span>$@detalleRenovacion.PrecioConDescuento</span>
                                </h5>
                            }
                            else
                            {
                                <h5 class="text-dark fw-bold mb-0 d-flex justify-content-between">
                                    <span>Total Final:</span>
                                    <span>$@detalleRenovacion.PrecioTotal</span>
                                </h5>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer bg-light border-0">
                    <button class="btn btn-secondary px-4" style="border-radius: 8px;" @onclick="CerrarModalRenovacion">Cancelar</button>
                    @if (detalleRenovacion.TurnosDisponibles)
                    {
                        <button class="btn btn-warning fw-bold text-dark px-4" style="border-radius: 8px;"
                                disabled="@detalleRenovacion.YaRenovo"
                                @onclick="ConfirmarRenovacion">
                            <i class="bi bi-credit-card-2-back-fill me-1"></i>
                            @(detalleRenovacion.YaRenovo ? "Ya Abonado" : "Confirmar y pagar")
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private Guid? paqueteIdDesplegado = null;
    [SupplyParameterFromQuery] public bool pagoExitoso { get; set; }
    [SupplyParameterFromQuery] public int? reservaId { get; set; }
    [SupplyParameterFromQuery] public string? tipo { get; set; }
    [SupplyParameterFromQuery(Name = "payment_id")] public string? PaymentId { get; set; }
    [SupplyParameterFromQuery] public int? userId { get; set; }
    private List<InscripcionListaEspera>? listaEspera;
    [SupplyParameterFromQuery] public int? turnoId { get; set; }
    [SupplyParameterFromQuery] public string? turnosId { get; set; }
    private bool mostrarModalRenovacion = false;
    private DetalleRenovacionDTO? detalleRenovacion;
    private Guid codigoPaqueteARenovar;

    private Dictionary<Guid, bool> estadosRenovacionPaquetes = new();

    public class PaqueteAgrupadoDTO
    {
        public Guid CodigoPaquete { get; set; }
        public string NombreActividad { get; set; } = string.Empty;
        public List<Reserva> ReservasAsociadas { get; set; } = new();
        public decimal PrecioUnitario { get; set; }
        public bool YaRenovo { get; set; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (UsuarioSesion.UsuarioActual == null && userId.HasValue)
        {
            var usuario = await ObtenerUsuarioPorId.Ejecutar(userId.Value);
            if (usuario != null)
            {
                UsuarioSesion.RestaurarSesion(usuario);
                await UsuarioSesion.NotificarCambio();
                StateHasChanged();
            }
        }

        if (reservaId.HasValue && tipo == "confirmarOcasional")
        {
            await ProcesarVueltaDeMP();
        }
        else if (turnoId.HasValue && tipo == "listaEspera")
        {
            await ProcesarVueltaMPListaEspera();
        }
        else if (tipo == "renovacion")
        {
            await ProcesarVueltaMPRenovacion();
        }
    }

    private async Task ProcesarVueltaDeMP()
    {
        if (pagoExitoso && !string.IsNullOrEmpty(PaymentId))
        {
            try
            {
                await ConfirmarPagoRestanteReservaOcasionalUseCase.Ejecutar(reservaId!.Value, PaymentId);
                error = "¡Pago procesado con éxito! Reserva confirmada.";
            }
            catch (Exception ex)
            {
                error = $"Error al confirmar el pago: {ex.Message}";
            }
        }
        else
        {
            error = "El pago fue cancelado o no pudo procesarse.";
        }

        await CargarReservas();
        StateHasChanged();
    }

    private async Task VerDetalleRenovacion(Guid codigoPaquete)
    {
        try
        {
            error = "";
            codigoPaqueteARenovar = codigoPaquete;
            detalleRenovacion = await ObtenerDetalleRenovacionUseCase.Ejecutar(
                UsuarioSesion.UsuarioActual!.Id, codigoPaquete);
            mostrarModalRenovacion = true;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void CerrarModalRenovacion()
    {
        mostrarModalRenovacion = false;
        detalleRenovacion = null;
    }

    private async Task ConfirmarRenovacion()
    {
        mostrarModalRenovacion = false;
        await RenovarPaquete(codigoPaqueteARenovar);
    }

    private IEnumerable<PaqueteAgrupadoDTO> ObtenerPaquetesAdelantados()
    {
        if (todasLasReservasAdelantadas == null) return Enumerable.Empty<PaqueteAgrupadoDTO>();

        return todasLasReservasAdelantadas
            .Where(r => r.CodigoPaqueteAdelantado.HasValue)
            .GroupBy(r => r.CodigoPaqueteAdelantado!.Value)
            .Select(g => new PaqueteAgrupadoDTO
            {
                CodigoPaquete = g.Key,
                NombreActividad = g.First().Turno?.Actividad?.Nombre ?? "Clase Adelantada",
                ReservasAsociadas = g.Where(r => r.Estado != EstadoReserva.Cancelado).ToList(),
                YaRenovo = estadosRenovacionPaquetes.ContainsKey(g.Key) && estadosRenovacionPaquetes[g.Key]
            });
    }

    private void AlternarDetallePaquete(Guid codigoPaquete)
    {
        if (paqueteIdDesplegado == codigoPaquete)
            paqueteIdDesplegado = null;
        else
            paqueteIdDesplegado = codigoPaquete;
    }

    private async Task RenovarPaquete(Guid codigoPaquete)
    {
        try
        {
            error = "";
            string urlRedireccion = await IniciarRenovarReservaAdelantadaUseCase.Ejecutar(
                UsuarioSesion.UsuarioActual!.Id, codigoPaquete);
            Navigation.NavigateTo(urlRedireccion, true);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task ProcesarVueltaMPRenovacion()
    {
        if (pagoExitoso && !string.IsNullOrEmpty(PaymentId) && !string.IsNullOrEmpty(turnosId))
        {
            try
            {
                var ids = turnosId.Split(',', StringSplitOptions.RemoveEmptyEntries)
                                  .Select(int.Parse)
                                  .ToList();
                await RenovarReservaAdelantadaUseCase.Ejecutar(
                    UsuarioSesion.UsuarioActual!.Id, ids, PaymentId);
                error = "¡Renovación realizada con éxito!";
            }
            catch (Exception ex)
            {
                error = $"Error al confirmar la renovación: {ex.Message}";
            }
        }
        else
        {
            error = "El pago no se pudo realizar. Intente nuevamente.";
        }

        await CargarReservas();
        StateHasChanged();
    }

    List<Reserva>? reservasActivas;
    private int tipoFiltroActivo = 1;
    private int? reservaSeleccionadaId;
    private byte[] qrCode = Array.Empty<byte>();
    private string error = "";
    private List<Reserva>? todasLasReservasAdelantadas;

    protected override async Task OnInitializedAsync()
    {
        error = "";
        await CargarReservas();
    }

    private async Task CargarReservas()
    {
        try
        {
            if (UsuarioSesion.UsuarioActual != null)
            {
                var idUsuario = UsuarioSesion.UsuarioActual.Id;

                var resultado = await listarReservasUseCase.Ejecutar(idUsuario);
                reservasActivas = resultado.Where(r => r.Estado != EstadoReserva.Cancelado).ToList();

                todasLasReservasAdelantadas = await ListarReservasClasesMensualesUseCase.Ejecutar(idUsuario);
                listaEspera = await ConsultarListaEsperaUseCase.Ejecutar(idUsuario);

                // PROCESAMIENTO ASÍNCRONO DEL MAPEO DEL CONTROL DE RENOVACIÓN
                if (todasLasReservasAdelantadas != null)
                {
                    var grupos = todasLasReservasAdelantadas
                        .Where(r => r.CodigoPaqueteAdelantado.HasValue)
                        .GroupBy(r => r.CodigoPaqueteAdelantado!.Value);

                    foreach (var g in grupos)
                    {
                        var primerTurno = g.First().Turno;
                        if (primerTurno != null)
                        {
                            int anioSiguiente = primerTurno.Fecha.Month == 12 ? primerTurno.Fecha.Year + 1 : primerTurno.Fecha.Year;
                            int mesSiguiente = primerTurno.Fecha.Month == 12 ? 1 : primerTurno.Fecha.Month + 1;

                            bool yaRenovo = await repoReserva.YaRenovoParaSiguienteMesAsync(
                                idUsuario,
                                primerTurno.Id_Actividad,
                                primerTurno.Fecha.DayOfWeek,
                                primerTurno.HoraInicio,
                                anioSiguiente,
                                mesSiguiente
                            );

                            estadosRenovacionPaquetes[g.Key] = yaRenovo;
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task PagarSaldoRestante(int idReserva)
    {
        try
        {
            error = "";
            string urlRedireccion = await CompletarPagoReservaCase.Ejecutar(idReserva);

            if (!string.IsNullOrEmpty(urlRedireccion))
            {
                Navigation.NavigateTo(urlRedireccion, true);
            }
            else
            {
                error = "No se pudo generar la pasarela de pago en este momento.";
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task ProcesarVueltaMPListaEspera()
    {
        if (pagoExitoso && !string.IsNullOrEmpty(PaymentId))
        {
            try
            {
                await CrearReservaListaEsperaUseCase.Ejecutar(
                    UsuarioSesion.UsuarioActual!.Id,
                    turnoId!.Value,
                    PaymentId);
                error = "¡Reserva confirmada! Ya tenés tu lugar en el turno.";
            }
            catch (Exception ex)
            {
                error = $"Error al confirmar la reserva: {ex.Message}";
            }
        }
        else
        {
            error = "El pago fue cancelado o no pudo procesarse.";
        }

        await CargarReservas();
        StateHasChanged();
    }

    private IEnumerable<Reserva> ObtenerReservasFiltradas()
    {
        if (reservasActivas == null) return Enumerable.Empty<Reserva>();

        return tipoFiltroActivo == 1
            ? reservasActivas.Where(r => r.TipoReserva == TipoReserva.Ocasional)
            : reservasActivas.Where(r => r.TipoReserva == TipoReserva.Adelantado);
    }

    async Task GenerarQr(int reservaId)
    {
        error = "";
        if (reservaSeleccionadaId == reservaId)
        {
            CerrarQr();
            return;
        }

        try
        {
            qrCode = await GenerarQRUseCase.Ejecutar(reservaId);
            reservaSeleccionadaId = reservaId;
        }
        catch (Exception ex)
        {
            error = ex.Message;
            StateHasChanged();
        }
    }

    void CerrarQr()
    {
        qrCode = Array.Empty<byte>();
        reservaSeleccionadaId = null;
    }

    async Task Cancelar(int idReserva)
    {
        try
        {
            var (conDevolucion, monto) = await cancelarReservasUseCase.Ejecutar(idReserva);

            error = conDevolucion
                ? $"Reserva cancelada exitosamente. Se ha generado una devolución de: ${monto}"
                : "Reserva cancelada exitosamente. No corresponde devolución.";

            await CargarReservas();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    async Task CancelarAdelantada(int idReserva)
    {
        try
        {
            var (seOtorgoCredito, mensaje) = await CancelarReservaAdelantadaUseCase.Ejecutar(
                UsuarioSesion.UsuarioActual!.Id, idReserva);
            error = mensaje;
            await CargarReservas();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task AbandonarLista(int idTurno)
    {
        try
        {
            error = "";
            await AbandonarListaEsperaUseCase.Ejecutar(UsuarioSesion.UsuarioActual!.Id, idTurno);
            error = "Has abandonado la lista de espera correctamente.";
            await CargarReservas();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private bool PuedeGenerarQr(Reserva r)
    {
        if (r.Estado != EstadoReserva.Confirmado && r.Estado != EstadoReserva.Reservado)
            return false;

        if (r.Asistencia != Asistencia.Ausente)
            return false;

        if (r.Turno!.Estado == EstadoTurno.Finalizado)
            return false;

        var fechaHoraTurno = r.Turno.Fecha.ToDateTime(r.Turno.HoraInicio);
        return DateTime.Now >= fechaHoraTurno.AddMinutes(-15);
    }

    private bool PuedeCancelar(Reserva r)
    {
        if (r.Asistencia != Asistencia.Ausente)
            return false;

        var fechaHoraTurno = r.Turno.Fecha.ToDateTime(r.Turno.HoraInicio);
        return DateTime.Now < fechaHoraTurno;
    }

    private async Task ReservarLugarLiberado(int idTurno)
    {
        try
        {
            error = "";
            string urlRedireccion = await IniciarPagoListaEsperaUseCase.Ejecutar(
                UsuarioSesion.UsuarioActual!.Id, idTurno);

            if (!string.IsNullOrEmpty(urlRedireccion))
                Navigation.NavigateTo(urlRedireccion, true);
            else
                error = "Ocurrió un error al intentar conectarse con la pasarela de pagos.";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }
