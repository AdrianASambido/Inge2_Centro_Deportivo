@page "/MiPerfil"
@rendermode InteractiveServer

@using CentroDeportivo.Aplicacion.Casos_de_uso.EstadisticaUseCase.DTOs
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador
@inject ConsultarHistorialUsuarioUseCase ConsultarHistorialUsuarioCase
@inject ConsultarCreditosUseCase ConsultarCreditosUseCase
@inject CentroDeportivo.Aplicacion.Casos_de_uso.PagoUseCase.DescargarComprobanteUseCase DescargarComprobanteUseCase
@inject IJSRuntime JS
@inject ConsultarPagosUseCase ConsultarPagosUseCase


<PageTitle>Mi Perfil</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-7">

            <div class="text-center mb-4">
                <h1 class="fw-bold text-primary">Mi Perfil</h1>
                <p class="text-muted">Gestiona la información y el historial de tu cuenta</p>
            </div>

            @if (UsuarioSesion.UsuarioActual == null)
            {
                <div class="card border-0 shadow-sm text-center p-5" style="border-radius: 16px;">
                    <div class="mb-3">
                        <i class="bi bi-exclamation-circle text-warning" style="font-size: 3rem;"></i>
                    </div>
                    <h4 class="mb-3">No hay usuario autenticado</h4>
                    <p class="text-muted mb-4">Debes iniciar sesión para ver los datos de tu perfil.</p>
                    <button class="btn btn-primary btn-lg px-5 shadow-sm" @onclick="IrLogin" style="border-radius: 10px;">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Ir al Login
                    </button>
                </div>
            }
            else
            {
                <div class="d-flex justify-content-center gap-2 gap-sm-3 mb-4">
                    <button class="btn py-2 px-3 text-center transition-all @(pestanaActiva == 1 ? "btn-primary text-white shadow" : "btn-light text-dark")"
                            style="min-width: 130px; border-radius: 12px;"
                            @onclick="() => pestanaActiva = 1">
                        <span class="fw-bold small">Mi Perfil</span>
                    </button>

                    <button class="btn py-2 px-3 text-center transition-all @(pestanaActiva == 2 ? "btn-primary text-white shadow" : "btn-light text-dark")"
                            style="min-width: 130px; border-radius: 12px;"
                            @onclick="() => pestanaActiva = 2">
                        <span class="fw-bold small">Consultar Historial</span>
                    </button>

                    <button class="btn py-2 px-3 text-center transition-all @(pestanaActiva == 3 ? "btn-primary text-white shadow" : "btn-light text-dark")"
                            style="min-width: 130px; border-radius: 12px;"
                            @onclick="() => pestanaActiva = 3">
                        <span class="fw-bold small">Listar Comprobantes</span>
                    </button>
                    <button class="btn py-2 px-3 text-center transition-all @(pestanaActiva == 4 ? "btn-primary text-white shadow" : "btn-light text-dark")"
                            style="min-width: 130px; border-radius: 12px;"
                            @onclick="() => pestanaActiva = 4">
                        <span class="fw-bold small">Mis Créditos</span>
                    </button>
                </div>

                <div class="card border-0 shadow-sm bg-white overflow-hidden" style="border-radius: 16px;">

                    @if (pestanaActiva == 1)
                    {
                        <div class="card-body p-4 p-md-5">
                            <h4 class="card-title fw-bold text-dark mb-4 text-center text-md-start">
                                <i class="bi bi-person-lines-fill me-2 text-primary"></i>Datos Personales
                            </h4>

                            <div class="list-group list-group-flush mb-4">
                                <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center">
                                    <span class="text-muted"><i class="bi bi-person me-2"></i>Nombre</span>
                                    <span class="fw-bold text-dark">@UsuarioSesion.UsuarioActual.Nombre</span>
                                </div>
                                <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center">
                                    <span class="text-muted"><i class="bi bi-person-badge me-2"></i>Apellido</span>
                                    <span class="fw-bold text-dark">@UsuarioSesion.UsuarioActual.Apellido</span>
                                </div>
                                <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center">
                                    <span class="text-muted"><i class="bi bi-card-text me-2"></i>DNI</span>
                                    <span class="fw-bold text-dark">@UsuarioSesion.UsuarioActual.Dni</span>
                                </div>
                                <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center">
                                    <span class="text-muted"><i class="bi bi-envelope me-2"></i>Email</span>
                                    <span class="fw-bold text-dark">@UsuarioSesion.UsuarioActual.Email</span>
                                </div>
                            </div>

                            <hr class="text-muted opacity-25" />

                            <div class="d-flex flex-column flex-sm-row justify-content-center gap-2 mt-4">
                                <NavLink class="btn btn-warning px-4 shadow-sm text-dark fw-bold" href="@($"/editar-usr/{UsuarioSesion.UsuarioActual.Id}")" style="border-radius: 8px;">
                                    <i class="bi bi-pencil-square me-2"></i>Editar perfil
                                </NavLink>

                                <NavLink class="btn btn-outline-secondary px-4 shadow-sm" href="@($"/cambiar-contrasenia/{UsuarioSesion.UsuarioActual.Id}")" style="border-radius: 8px;">
                                    <i class="bi bi-shield-lock me-2"></i>Contraseña
                                </NavLink>

                                <button class="btn btn-danger px-4 shadow-sm" @onclick="CerrarSesion" style="border-radius: 8px;">
                                    <i class="bi bi-box-arrow-left me-2"></i>Salir
                                </button>
                            </div>
                        </div>
                    }
                    else if (pestanaActiva == 2)
                    {
                        <div class="card-body p-4 p-md-5">
                            <h4 class="card-title fw-bold text-dark mb-4 text-center text-md-start">
                                <i class="bi bi-clock-history me-2 text-primary"></i>Historial de Actividad
                            </h4>

                            @if (historial != null && historial.Any())
                            {
                                <div class="table-responsive border rounded-3 bg-white">
                                    <table class="table table-hover align-middle m-0 text-center">
                                        <thead class="table-light">
                                            <tr class="text-muted small text-uppercase">
                                                <th class="text-start ps-3">Actividad</th>
                                                <th>Asistencias</th>
                                                <th>Inasistencias</th>
                                                <th>Cancelaciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var h in historial)
                                            {
                                                <tr>
                                                    <td class="fw-bold text-start ps-3 text-primary">@h.NombreActividad</td>
                                                    <td><span class="badge bg-success-subtle text-success fs-6 px-3">@h.TotalAsistencias</span></td>
                                                    <td><span class="badge bg-danger-subtle text-danger fs-6 px-3">@h.TotalInasistencias</span></td>
                                                    <td><span class="badge bg-secondary-subtle text-secondary fs-6 px-3">@h.TotalCancelaciones</span></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-4 text-muted">
                                    <i class="bi bi-calendar-x fs-3 d-block mb-2"></i>
                                    @(!string.IsNullOrEmpty(mensaje) ? mensaje : "No registra actividad deportiva en el sistema.")
                                </div>
                            }
                        </div>
                    }
                    else if (pestanaActiva == 3)
{
    <div class="card-body p-4 p-md-5">
        <h4 class="card-title fw-bold text-dark mb-4 text-center text-md-start">
            <i class="bi bi-receipt me-2 text-primary"></i>Comprobantes de Pago
        </h4>

        @if (comprobantes != null && comprobantes.Any())
        {
            <div class="table-responsive border rounded-3 bg-white">
                <table class="table table-hover align-middle m-0 text-center">
                    <thead class="table-light">
                        <tr class="text-muted small text-uppercase">
                            <th class="text-start ps-3">Nro. Pago</th>
                            <th>Fecha</th>
                            <th>Monto</th>
                            <th>Método</th>
                            <th class="text-end pe-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pago in comprobantes)
                        {
                            <tr>
                                <td class="fw-bold text-start ps-3">#@pago.Id</td>
                                <td>@pago.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-success fw-bold">$ @pago.Monto</td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        <i class="bi bi-credit-card-2-front me-1"></i>
                                    </span>
                                </td>
                                <td class="text-end pe-3">
                                    <button class="btn btn-outline-primary btn-sm fw-bold" 
                                            @onclick="() => DescargarPdf(pago.Id)"
                                            disabled="@descargandoId.HasValue">
                                        @if (descargandoId == pago.Id)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-download me-1"></i>
                                        }
                                        Descargar
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted bg-light rounded-3 border">
                <i class="bi bi-file-earmark-x fs-2 text-secondary mb-3 d-block"></i>
                <p class="mb-0 fw-bold">No posee comprobantes de pago.</p>
            </div>
        }
    </div>  
}
                    else if (pestanaActiva == 4)
{
    <h5 class="fw-bold mb-4">
        <i class="bi bi-wallet2 me-2 text-primary"></i>Mis Créditos
    </h5>

    @if (creditos != null && creditos.Any())
    {
        <div class="table-responsive border rounded-3">
            <table class="table table-hover align-middle m-0 text-center tabla-comprobantes">
                <thead class="table-light">
                    <tr>
                        <th class="text-start ps-3">Actividad</th>
                        <th>Fecha de generación</th>
                        <th>Vencimiento</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var credito in creditos)
                    {
                        <tr>
                            <td class="text-start ps-3 fw-bold text-primary">@credito.Actividad?.Nombre</td>
                            <td class="text-muted">@credito.FechaGeneracion.ToString("dd/MM/yyyy")</td>
                            <td class="text-muted">@credito.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge @(credito.Estado == EstadoCredito.Disponible ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">
                                    @credito.Estado
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
{
    <div class="text-center py-4 text-muted">
        <p class="mb-0">Usted no posee créditos en este momento.</p>
    </div>
}
}
                </div>
            }
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(mensaje) && pestanaActiva == 1)
{
    <div class="alert alert-info mt-3 shadow-sm mx-auto text-center" style="max-width: 500px;">@mensaje</div>
}

@code {
    private int pestanaActiva = 1;
    private List<HistorialUsuarioActividadDTO>? historial;
    private List<Credito>? creditos;
    private string mensaje = "";
    private List<Pago>? comprobantes; 
    private int? descargandoId = null;
    private string error = "";

    protected override async Task OnInitializedAsync()
{
    try
    {
        if (UsuarioSesion.UsuarioActual == null)
        {
            mensaje = "Debe iniciar sesión.";
            return;
        }

        var resultado = await ConsultarHistorialUsuarioCase.Ejecutar(UsuarioSesion.UsuarioActual.Id);
        historial = resultado?.ToList() ?? new List<HistorialUsuarioActividadDTO>();

        creditos = (await ConsultarCreditosUseCase.Ejecutar(UsuarioSesion.UsuarioActual.Id))?.ToList() ?? new();

        var pagos = await ConsultarPagosUseCase.Ejecutar(UsuarioSesion.UsuarioActual.Id);
        comprobantes = pagos?.ToList() ?? new List<Pago>();
    }
    catch (Exception ex)
    {
        mensaje = ex.Message;
    }
}
    private async Task DescargarPdf(int pagoId)
{
    try
    {
        error = "";
        descargandoId = pagoId;
        StateHasChanged();

        byte[] pdfBytes = await DescargarComprobanteUseCase.Ejecutar(pagoId, UsuarioSesion.UsuarioActual!.Id);

        if (pdfBytes is { Length: > 0 })
        {
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("eval", $@"
                const a = document.createElement('a');
                a.href = 'data:application/pdf;base64,{base64}';
                a.download = 'Comprobante_Pago_{pagoId}.pdf';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
            ");
        }
        else
        {
            error = "No se pudo generar el comprobante. Intentá de nuevo.";
        }
    }
    catch (Exception ex)
    {
        error = "No se pudo generar el comprobante. Intentá de nuevo.";
        Console.WriteLine($"[PDF ERROR] {ex}");
    }
    finally
    {
        descargandoId = null;
        StateHasChanged();
    }
}
    void IrLogin()
    {
        Navegador.NavigateTo("/Login");
    }

    void CerrarSesion()
    {
        UsuarioSesion.CerrarSesion();
        UsuarioSesion.NotificarCambio();
        Navegador.NavigateTo("/Login", true);
    }
}