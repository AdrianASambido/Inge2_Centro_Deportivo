@page "/MiPerfil"
@rendermode InteractiveServer

@using CentroDeportivo.Aplicacion.Casos_de_uso.EstadisticaUseCase.DTOs
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador
@inject ConsultarHistorialUsuarioUseCase ConsultarHistorialUsuarioCase
@inject ConsultarCreditosUseCase ConsultarCreditosUseCase
@inject ConsultarPagosUseCase ConsultarPagosUseCase
@inject DescargarComprobanteUseCase DescargarComprobanteUseCase
@inject IJSRuntime JS

<PageTitle>Mi Perfil</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 @(pestanaActiva == 1 ? "col-md-10 col-lg-7" : "col-md-11 col-lg-10")">

            <div class="text-center mb-4">
                <h1 class="fw-bold text-primary">Mi Perfil</h1>
                <p class="text-muted">Gestiona la información y el historial de tu cuenta</p>
            </div>

            @if (UsuarioSesion.UsuarioActual == null)
            {
                <div class="card border-0 shadow-sm text-center p-5" style="border-radius: 16px;">
                    <div class="mb-3">
                        <i class="bi bi-exclamation-circle text-warning" style="font-size: 3rem;"></i>
                    </div>
                    <h4 class="mb-3">No hay usuario autenticado</h4>
                    <p class="text-muted mb-4">Debes iniciar sesión para ver los datos de tu perfil.</p>
                    <button class="btn btn-primary btn-lg px-5 shadow-sm" @onclick="IrLogin" style="border-radius: 10px;">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Ir al Login
                    </button>
                </div>
            }
            else
            {
                <div class="d-flex justify-content-center gap-2 gap-sm-3 mb-4">
                    <button class="btn py-2 px-3 text-center @(pestanaActiva == 1 ? "btn-primary text-white shadow" : "btn-light text-dark")"
                            style="min-width: 130px; border-radius: 12px;"
                            @onclick="() => pestanaActiva = 1">
                        <span class="fw-bold small">Mi Perfil</span>
                    </button>
                    <button class="btn py-2 px-3 text-center @(pestanaActiva == 2 ? "btn-primary text-white shadow" : "btn-light text-dark")"
                            style="min-width: 130px; border-radius: 12px;"
                            @onclick="() => pestanaActiva = 2">
                        <span class="fw-bold small">Historial</span>
                    </button>
                    <button class="btn py-2 px-3 text-center @(pestanaActiva == 3 ? "btn-primary text-white shadow" : "btn-light text-dark")"
                            style="min-width: 130px; border-radius: 12px;"
                            @onclick="() => pestanaActiva = 3">
                        <span class="fw-bold small">Comprobantes</span>
                    </button>
                    <button class="btn py-2 px-3 text-center @(pestanaActiva == 4 ? "btn-primary text-white shadow" : "btn-light text-dark")"
                            style="min-width: 130px; border-radius: 12px;"
                            @onclick="() => pestanaActiva = 4">
                        <span class="fw-bold small">Mis Créditos</span>
                    </button>
                </div>

                <div class="card border-0 shadow-sm bg-white overflow-hidden" style="border-radius: 16px;">

                    @if (pestanaActiva == 1)
                    {
                        <div class="card-body p-4 p-md-5">
                            <h4 class="card-title fw-bold text-dark mb-4 text-center text-md-start">
                                <i class="bi bi-person-lines-fill me-2 text-primary"></i>Datos Personales
                            </h4>
                            <div class="list-group list-group-flush mb-4">
                                <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center">
                                    <span class="text-muted"><i class="bi bi-person me-2"></i>Nombre</span>
                                    <span class="fw-bold text-dark">@UsuarioSesion.UsuarioActual.Nombre</span>
                                </div>
                                <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center">
                                    <span class="text-muted"><i class="bi bi-person-badge me-2"></i>Apellido</span>
                                    <span class="fw-bold text-dark">@UsuarioSesion.UsuarioActual.Apellido</span>
                                </div>
                                <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center">
                                    <span class="text-muted"><i class="bi bi-card-text me-2"></i>DNI</span>
                                    <span class="fw-bold text-dark">@UsuarioSesion.UsuarioActual.Dni</span>
                                </div>
                                <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center">
                                    <span class="text-muted"><i class="bi bi-envelope me-2"></i>Email</span>
                                    <span class="fw-bold text-dark">@UsuarioSesion.UsuarioActual.Email</span>
                                </div>
                            </div>
                            <hr class="text-muted opacity-25" />
                            <div class="d-flex flex-column flex-sm-row justify-content-center gap-2 mt-4">
                                <NavLink class="btn btn-warning px-4 shadow-sm text-dark fw-bold"
                                         href="@($"/editar-usr/{UsuarioSesion.UsuarioActual.Id}")"
                                         style="border-radius: 8px;">
                                    <i class="bi bi-pencil-square me-2"></i>Editar perfil
                                </NavLink>
                                <NavLink class="btn btn-outline-secondary px-4 shadow-sm"
                                         href="@($"/cambiar-contrasenia/{UsuarioSesion.UsuarioActual.Id}")"
                                         style="border-radius: 8px;">
                                    <i class="bi bi-shield-lock me-2"></i>Contraseña
                                </NavLink>
                                <button class="btn btn-danger px-4 shadow-sm" @onclick="CerrarSesion" style="border-radius: 8px;">
                                    <i class="bi bi-box-arrow-left me-2"></i>Salir
                                </button>
                            </div>
                        </div>
                    }
                    else if (pestanaActiva == 2)
                    {
                        <div class="card-body p-4 p-md-5">
                            <h4 class="card-title fw-bold text-dark mb-4 text-center text-md-start">
                                <i class="bi bi-clock-history me-2 text-primary"></i>Historial de Actividad
                            </h4>
                            @if (historial != null && historial.Any())
                            {
                                <div class="table-responsive border rounded-3 bg-white">
                                    <table class="table table-hover align-middle m-0 text-center">
                                        <thead class="table-light">
                                            <tr class="text-muted small text-uppercase">
                                                <th class="text-start ps-3">Actividad</th>
                                                <th>Asistencias</th>
                                                <th>Inasistencias</th>
                                                <th>Cancelaciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var h in historial)
                                            {
                                                <tr>
                                                    <td class="fw-bold text-start ps-3 text-primary">@h.NombreActividad</td>
                                                    <td><span class="badge bg-success-subtle text-success fs-6 px-3">@h.TotalAsistencias</span></td>
                                                    <td><span class="badge bg-danger-subtle text-danger fs-6 px-3">@h.TotalInasistencias</span></td>
                                                    <td><span class="badge bg-secondary-subtle text-secondary fs-6 px-3">@h.TotalCancelaciones</span></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-4 text-muted">
                                    <i class="bi bi-calendar-x fs-3 d-block mb-2"></i>
                                    No registra actividad deportiva en el sistema.
                                </div>
                            }
                        </div>
                    }
                    else if (pestanaActiva == 3)
                    {
                        <!-- Forzamos a que el contenido use el ancho completo en tablas -->
                        <div class="card-body p-3 p-md-4">
                            <h4 class="card-title fw-bold text-dark mb-4 text-center text-md-start">
                                <i class="bi bi-receipt me-2 text-primary"></i>Comprobantes de Pago
                            </h4>

                            @if (!string.IsNullOrEmpty(mensajePago))
                            {
                                <div class="alert alert-danger">@mensajePago</div>
                            }

                            @if (pagos != null && pagos.Any())
                            {
                                <!-- 'text-nowrap' evita que las fechas o botones se partan en dos renglones desprolijamente -->
                                <div class="table-responsive border rounded-3 bg-white text-nowrap">
                                    <table class="table table-hover align-middle m-0">
                                        <thead class="table-light">
                                            <tr class="text-muted small text-uppercase">
                                                <th class="ps-3">Fecha</th>
                                                <th>Actividad</th>
                                                <th>Monto</th>
                                                <th class="text-end pe-3">Comprobante</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var p in pagos)
                                            {
                                                <tr>
                                                    <td class="ps-3">@p.Fecha.ToString("dd/MM/yyyy")</td>
                                                    <td>
                                                        @(p.Reserva?.Turno?.Actividad?.Nombre
                                                          ?? p.Turno?.Actividad?.Nombre
                                                          ?? "Pago")
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-success-subtle text-success fs-6 px-3">
                                                            $ @p.Monto
                                                        </span>
                                                    </td>
                                                    <td class="text-end pe-3">
                                                        <button class="btn btn-outline-primary btn-sm"
                                                                @onclick="() => DescargarComprobante(p.Id)">
                                                            <i class="bi bi-download me-1"></i> Descargar
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-4 text-muted">
                                    <i class="bi bi-credit-card-2-back fs-3 d-block mb-2"></i>
                                    No registra comprobantes de pago.
                                </div>
                            }
                        </div>
                    }
                    else if (pestanaActiva == 4)
                    {
                        <div class="card-body p-3 p-md-4">
                            <h4 class="card-title fw-bold text-dark mb-4 text-md-start">
                                <i class="bi bi-wallet2 me-2 text-primary"></i>Créditos disponibles
                            </h4>

                            @if (creditos != null && creditos.Any())
                            {
                                <div class="table-responsive border rounded-3 bg-white text-nowrap">
                                    <table class="table table-hover align-middle m-0">
                                        <thead class="table-light">
                                            <tr class="text-muted small text-uppercase">
                                                <th class="ps-3">Actividad</th>
                                                <th>Generado</th>
                                                <th>Vence</th>
                                                <th>Estado</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var c in creditos)
                                            {
                                                <tr>
                                                    <td class="ps-3 fw-bold text-primary">
                                                        @(c.Actividad?.Nombre ?? "-")
                                                    </td>
                                                    <td>@c.FechaGeneracion.ToString("dd/MM/yyyy")</td>
                                                    <td>@c.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                                                    <td>
                                                        <span class="badge @(c.Estado == EstadoCredito.Disponible ? "bg-success" : "bg-secondary")">
                                                            @c.Estado
                                                        </span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-4 text-muted">
                                    <i class="bi bi-wallet2 fs-3 d-block mb-2"></i>
                                    No registra créditos disponibles.
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private int pestanaActiva = 1;
    private List<HistorialUsuarioActividadDTO>? historial;
    private List<Credito>? creditos;
    private List<Pago>? pagos;
    private string mensaje = "";
    private string mensajePago = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (UsuarioSesion.UsuarioActual == null)
            {
                mensaje = "Debe iniciar sesión.";
                return;
            }

            var idUsuario = UsuarioSesion.UsuarioActual.Id;

            var resultadoHistorial = await ConsultarHistorialUsuarioCase.Ejecutar(idUsuario);
            historial = resultadoHistorial?.ToList() ?? new();

            var resultadoCreditos = await ConsultarCreditosUseCase.Ejecutar(idUsuario);
            creditos = resultadoCreditos?.ToList() ?? new();

            var resultadoPagos = await ConsultarPagosUseCase.Ejecutar(idUsuario);
            pagos = resultadoPagos?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            mensaje = ex.Message;
        }
    }

    private async Task DescargarComprobante(int pagoId)
    {
        mensajePago = "";
        try
        {
            var pdf = await DescargarComprobanteUseCase.Ejecutar(pagoId, UsuarioSesion.UsuarioActual!.Id);
            var base64 = Convert.ToBase64String(pdf);
            await JS.InvokeVoidAsync("downloadFileFromBase64", base64, $"comprobante_{pagoId}.pdf", "application/pdf");
        }
        catch (Exception ex)
        {
            mensajePago = ex.Message;
        }
    }

    void IrLogin() => Navegador.NavigateTo("/Login");

    void CerrarSesion()
    {
        UsuarioSesion.CerrarSesion();
        UsuarioSesion.NotificarCambio();
        Navegador.NavigateTo("/Login", true);
    }
}