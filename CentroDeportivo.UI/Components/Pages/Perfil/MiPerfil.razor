@page "/MiPerfil"
@rendermode InteractiveServer

@inject Sesion UsuarioSesion
@inject NavigationManager Navegador

<PageTitle>Mi Perfil</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            
            <div class="text-center mb-4">
                <h1 class="fw-bold text-primary">Mi Perfil</h1>
                <p class="text-muted">Gestiona la información de tu cuenta</p>
            </div>

            @if (UsuarioSesion.UsuarioActual == null)
            {
                <div class="card border-0 shadow-sm text-center p-5">
                    <div class="mb-3">
                        <i class="bi bi-exclamation-circle text-warning" style="font-size: 3rem;"></i>
                    </div>
                    <h4 class="mb-3">No hay usuario autenticado</h4>
                    <p class="text-muted mb-4">Debes iniciar sesión para ver los datos de tu perfil.</p>
                    <button class="btn btn-primary btn-lg px-5 shadow-sm" @onclick="IrLogin">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Ir al Login
                    </button>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-lg overflow-hidden">
                    <div class="bg-primary p-4 text-center">
                        <div class="rounded-circle bg-white d-inline-flex align-items-center justify-content-center shadow" style="width: 80px; height: 80px;">
                            <i class="bi bi-person-fill text-primary" style="font-size: 2.5rem;"></i>
                        </div>
                    </div>

                    <div class="card-body p-4">
                        <h3 class="card-title text-center mb-4">Datos del usuario</h3>
                        
                        <div class="list-group list-group-flush mb-4">
                            <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center">
                                <span class="text-muted"><i class="bi bi-person me-2"></i>Nombre</span>
                                <span class="fw-bold">@UsuarioSesion.UsuarioActual.Nombre</span>
                            </div>
                            <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center">
                                <span class="text-muted"><i class="bi bi-person-badge me-2"></i>Apellido</span>
                                <span class="fw-bold">@UsuarioSesion.UsuarioActual.Apellido</span>
                            </div>
                            <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center">
                                <span class="text-muted"><i class="bi bi-envelope me-2"></i>DNI</span>
                                <span class="fw-bold">@UsuarioSesion.UsuarioActual.Dni</span>
                            </div>
                            <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center">
                                <span class="text-muted"><i class="bi bi-envelope me-2"></i>Email</span>
                                <span class="fw-bold">@UsuarioSesion.UsuarioActual.Email</span>
                            </div>
                        </div>

                        <hr class="text-muted opacity-25" />

                        <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-4">
                            <NavLink class="btn btn-warning px-4 shadow-sm"
                                     href="@($"/editar-usr/{UsuarioSesion.UsuarioActual.Id}")">
                                <i class="bi bi-pencil-square me-2"></i>Editar perfil
                            </NavLink>
                            
                            <NavLink class="btn btn-outline-secondary px-4 shadow-sm"
                                     href="@($"/cambiar-contrasenia/{UsuarioSesion.UsuarioActual.Id}")">
                                <i class="bi bi-shield-lock me-2"></i>Contraseña
                            </NavLink>

                            <button class="btn btn-danger px-4 shadow-sm"
                                    @onclick="CerrarSesion">
                                <i class="bi bi-box-arrow-left me-2"></i>Salir
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    void IrLogin()
    {
        Navegador.NavigateTo("/Login");
    }

    void CerrarSesion()
    {
        UsuarioSesion.CerrarSesion(); UsuarioSesion.NotificarCambio(); Navegador.NavigateTo("/Login", true);
    }
}