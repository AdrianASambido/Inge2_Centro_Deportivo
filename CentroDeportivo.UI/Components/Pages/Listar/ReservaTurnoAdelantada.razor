@page "/Turno/adelantada"
@rendermode InteractiveServer
@inject NavigationManager Navegador
@inject IJSRuntime JS
@using System.Globalization
@inject Sesion UsuarioSesion
@inject ObtenerClasesAdelantadasDisponiblesUseCase ObtenerClasesAdelantadasDisponiblesUseCase
@inject ObtenerActividadPorId ObtenerActividadPorId
@inject CrearReservaAdelantadaUseCase CrearReservaAdelantadaUseCase
@inject IniciarReservaAdelantadaUseCase IniciarReservaAdelantadaUseCase
@inject ObtenerTurnoId ObtenerTurnoPorId
@inject ObtenerUsuarioPorId ObtenerUsuarioPorId

<PageTitle>Horarios del mes</PageTitle>

@if (UsuarioSesion.UsuarioActual is null)
{
    <div class="alert alert-warning">Debe iniciar sesión. <NavLink href="/Login">Ir al Login</NavLink></div>
}
else if (!parametrosOk)
{
    <div class="container-fluid p-0">
        <div class="alert alert-warning">Indique actividad y fecha válida.</div>
        <button type="button" class="btn btn-secondary" @onclick="VolverTurnos">Volver</button>
    </div>
}
else
{
    <div class="container-fluid p-0">
        <h2 class="mb-1">@actividadNombre</h2>
        <p class="text-muted mb-4">
            Día: @Transformar()
        </p>

        @if (!string.IsNullOrEmpty(mensajeExito))
        {
            <div class="alert alert-success shadow-sm">@mensajeExito</div>
        }
        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="alert alert-danger shadow-sm">@mensajeError</div>
        }

        <div class="mb-3">
            <label class="form-label fw-bold">Mes a reservar</label>
            <select class="form-select" style="max-width: 250px;" @bind="mesSeleccionado" @bind:after="CargarTurnos">
                <option value="@MesActual()">@NombreMes(DateTime.Now.Year, DateTime.Now.Month)</option>
                <option value="@MesProximo()">@NombreMes(AnioProximo(), NumeroMesProximo())</option>
            </select>
        </div>

        <div class="row">
            <div class="col-12 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white fw-bold">Turnos Disponibles</div>
                    <ul class="list-group list-group-flush">
                        @if (clasesDisponibles.Any())
                        {
                            @foreach (var clase in clasesDisponibles)
                            {
                                var t = clase.TurnoRepresentativo;
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fw-bold">@Transformar()</span>
                                        <span class="fw-bold">
                                            @t.HoraInicio.ToString("HH:mm") – @t.HoraFin.ToString("HH:mm")
                                        </span>
                                        <div class="small text-muted">Profesor: @t.Profesor.Nombre</div>
                                        <div class="small text-muted">Cupo mínimo disponible: @clase.CupoMinimoDisponible</div>
                                        <div class="small text-muted">Cantidad de clases: @clase.TurnosDelMes.Count</div>
                                    </div>
                                    <button class="btn btn-success"
                                            disabled="@procesando"
                                            @onclick="() => Reservar(clase)">
                                        Reservar mes
                                    </button>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-center py-4 text-muted">
                                No hay turnos disponibles para reservar en este mes.
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <button type="button" class="btn btn-secondary mt-2" @onclick="VolverTurnos">Volver a turnos</button>
    </div>
}

@code {
    [SupplyParameterFromQuery] public int? ActividadId { get; set; }
    [SupplyParameterFromQuery] public int? DiaSemana { get; set; }
    [SupplyParameterFromQuery] public bool pagoExitoso { get; set; }
    [SupplyParameterFromQuery] public bool volviMP { get; set; }
    [SupplyParameterFromQuery(Name = "payment_id")] public string? PaymentId { get; set; }
    [SupplyParameterFromQuery] public string? turnosId { get; set; }
    [SupplyParameterFromQuery] public int? UserId { get; set; }
    [SupplyParameterFromQuery] public int? anio { get; set; }
    [SupplyParameterFromQuery] public int? mes { get; set; }

    private bool parametrosOk;
    private string actividadNombre = "";
    private bool procesando;
    private string? mensajeExito;
    private string? mensajeError;
    private List<ClaseAdelantada> clasesDisponibles = new();

    // mes seleccionado: formato "yyyy-MM"
    private string mesSeleccionado = $"{DateTime.Now.Year}-{DateTime.Now.Month:D2}";

    // helpers de mes
    private string MesActual() => $"{DateTime.Now.Year}-{DateTime.Now.Month:D2}";
    private string MesProximo() => $"{AnioProximo()}-{NumeroMesProximo():D2}";
    private int NumeroMesProximo() => DateTime.Now.Month == 12 ? 1 : DateTime.Now.Month + 1;
    private int AnioProximo() => DateTime.Now.Month == 12 ? DateTime.Now.Year + 1 : DateTime.Now.Year;
    private string NombreMes(int anio, int mes)
    {
        var nombre = new DateTime(anio, mes, 1).ToString("MMMM yyyy", new CultureInfo("es-AR"));
        return char.ToUpper(nombre[0]) + nombre[1..];
    }
    private (int anio, int mes) ParsearMes()
    {
        var partes = mesSeleccionado.Split('-');
        return (int.Parse(partes[0]), int.Parse(partes[1]));
    }

    private string NombreDia(DayOfWeek dia)
    {
        var nombre = CultureInfo.GetCultureInfo("es-AR").DateTimeFormat.GetDayName(dia);
        return char.ToUpper(nombre[0]) + nombre[1..];
    }
    private string Transformar()
    {
        if (DiaSemana is null) return "";
        return NombreDia((DayOfWeek)DiaSemana.Value);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && volviMP)
        {
            if (UsuarioSesion.UsuarioActual is null && UserId.HasValue)
            {
                var usuario = await ObtenerUsuarioPorId.Ejecutar(UserId.Value);
                if (usuario != null)
                {
                    UsuarioSesion.RestaurarSesion(usuario);
                    UsuarioSesion.NotificarCambio();
                }
            }

            await ProcesarVueltaDeMP();
            StateHasChanged();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // parseamos parámetros siempre para que parametrosOk sea correcto al volver de MP
        if (ActividadId is > 0 && DiaSemana is >= 0 and <= 6)
            parametrosOk = true;
        else
            parametrosOk = false;

        if (UsuarioSesion.UsuarioActual is null) return;
        if (volviMP) return; // lo maneja OnAfterRenderAsync

        procesando = true;
        mensajeError = mensajeExito = null;

        if (!parametrosOk)
        {
            procesando = false;
            return;
        }

        try
        {
            var act = await ObtenerActividadPorId.Ejecutar(ActividadId!.Value);
            actividadNombre = act?.Nombre ?? "Actividad";
            await CargarTurnos();
        }
        catch (Exception ex)
        {
            mensajeError = "Error de carga: " + ex.Message;
        }
        finally
        {
            procesando = false;
        }
    }

    private async Task ProcesarVueltaDeMP()
    {
        if (!volviMP) return;

        if (ActividadId.HasValue)
        {
            var act = await ObtenerActividadPorId.Ejecutar(ActividadId.Value);
            actividadNombre = act?.Nombre ?? "Actividad";
        }

        if (pagoExitoso)
        {
            var idsTurnos = turnosId?
                .Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(int.Parse)
                .ToList() ?? new();

            var turnos = new List<Turno>();
            foreach (var id in idsTurnos)
            {
                var turno = await ObtenerTurnoPorId.Ejecutar(id);
                if (turno != null)
                    turnos.Add(turno);
            }

            await CrearReservaAdelantadaUseCase.Ejecutar(
                UsuarioSesion.UsuarioActual!.Id,
                turnos,
                PaymentId!);

            mensajeExito = "Pago y reserva realizados con éxito.";
            await CargarTurnos();
        }
        else
        {
            mensajeError = "El pago no se pudo realizar. Intente nuevamente.";
            await CargarTurnos();
        }
    }

    private async Task CargarTurnos()
    {
        if (!parametrosOk || DiaSemana is null || ActividadId is null) return;

        int anioBusqueda = anio ?? int.Parse(mesSeleccionado.Split('-')[0]);
        int mesBusqueda = mes ?? int.Parse(mesSeleccionado.Split('-')[1]);

        mesSeleccionado = $"{anioBusqueda}-{mesBusqueda:D2}";

        var dia = (DayOfWeek)DiaSemana.Value;

        clasesDisponibles = (await ObtenerClasesAdelantadasDisponiblesUseCase.Ejecutar(
            ActividadId.Value, dia, UsuarioSesion.UsuarioActual!.Id, anioBusqueda, mesBusqueda)).ToList();
    }

    private async Task Reservar(ClaseAdelantada clase)
    {
        procesando = true;
        mensajeError = mensajeExito = null;

        try
        {
            string urlPagoMercadoPago = await IniciarReservaAdelantadaUseCase.Ejecutar(
                UsuarioSesion.UsuarioActual!.Id,
                clase.TurnosDelMes
            );
            Navegador.NavigateTo(urlPagoMercadoPago, forceLoad: true);
        }
        catch (Exception ex)
        {
            mensajeError = ex.Message;
            procesando = false;
            StateHasChanged();
        }
    }

    private void VolverTurnos() => Navegador.NavigateTo("/Turnos");
}