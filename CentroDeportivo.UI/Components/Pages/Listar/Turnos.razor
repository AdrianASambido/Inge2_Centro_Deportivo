@page "/Turnos"
@rendermode InteractiveServer
@using System.Globalization
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador
@inject ListarActividadesUseCase ListarActividadesUseCase

<PageTitle>Reserva de turnos</PageTitle>

<div class="container py-4">
    <h2 class="text-center">Bienvenido a la reserva de turnos</h2>

    @if (UsuarioSesion.UsuarioActual is null)
    {
        <p class="text-center">Redirigiendo al inicio de sesión…</p>
    }
    else
    {
        <p class="text-center">@UsuarioSesion.UsuarioActual.Nombre @UsuarioSesion.UsuarioActual.Apellido</p>

        <div class="Contenedor-de-pestanias">
            <button class="tab-boton @(pestañaActiva == 1 ? "activo" : "")" @onclick="() => pestañaActiva = 1">Reserva ocasional</button>
            <button class="tab-boton @(pestañaActiva == 2 ? "activo" : "")" @onclick="() => pestañaActiva = 2">Reserva adelantada</button>
        </div>

        @if (pestañaActiva == 1)
        {
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <label class="form-label">Actividad</label>
                    <select class="form-select" @bind="SeleccionActividad" @bind:after="AlActividadCambiada">
                        <option value="">— Seleccione una actividad —</option>
                        @foreach (var a in actividades)
                        {
                            <option value="@a.Id">@a.Nombre</option>
                        }
                    </select>
                </div>
            </div>

            @if (int.TryParse(SeleccionActividad, out var aid) && aid > 0)
            {
                <div class="text-center my-4">
                    <div class="position-relative d-inline-block">
                        <button type="button"
                        class="btn btn-primary"
                        @onclick="AlternarCalendarioCompleto"
                        @onmouseenter="MostrarCalendarioMini"
                        @onmouseleave="OcultarCalendarioMini">
                            Reservar turnos
                        </button>

                        @if (mostrarCalendarioMini)
                        {
                            <div class="card position-absolute top-100 start-50 translate-middle-x mt-2 p-2 shadow" style="z-index: 1080; min-width: 220px;">
                                <div class="small text-muted text-center">@TituloMes(ReferenciaMes)</div>
                                @TablaCalendario(esMini: true, actividadParaNavegar: aid)
                            </div>
                        }
                    </div>
                </div>

                @if (mostrarCalendarioCompleto)
                {
                    <div class="row justify-content-center">
                        <div class="col-auto">

                            <div class="d-flex justify-content-center align-items-center gap-2 mb-2">
                                <button class="btn btn-outline-secondary btn-sm"
                                @onclick="MesAnterior"
                                disabled="@EsMesActual()">
                                    ←
                                </button>

                                <span class="fw-semibold">
                                    @TituloMes(ReferenciaMes)
                                </span>

                                <button class="btn btn-outline-secondary btn-sm"
                                @onclick="MesSiguiente">
                                    →
                                </button>
                            </div>

                            @TablaCalendario(esMini: false, actividadParaNavegar: aid)

                        </div>
                    </div>
                }
            }
        }

        @if (pestañaActiva == 2)
        {
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label">Actividad</label>
                        <select class="form-select" @bind="SeleccionActividad" @bind:after="AlActividadCambiada">
                            <option value="">— Seleccione una actividad —</option>
                            @foreach (var a in actividades)
                            {
                                <option value="@a.Id">@a.Nombre</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Dia de la semana</label>
                        <select class="form-select" @bind="diaSemana">
                            @foreach (var d in Enum.GetValues<DayOfWeek>())
                                {
                                    <option value="@d">@NombreDia(d)</option>
                                }
                        </select>
                    </div>
                </div>
            </div>

            @if (int.TryParse(SeleccionActividad, out var aid2) && aid2 > 0)
            {
                <button class="btn btn-primary"
                @onclick="() => IrAActividad(aid2, diaSemana)">
                    Continuar
                </button>
            }
        }
    }
</div>

@code {
    private string NombreDia(DayOfWeek dia)
    {
        var nombre = CultureInfo.GetCultureInfo("es-AR").DateTimeFormat.GetDayName(dia);
        return char.ToUpper(nombre[0]) + nombre[1..];
    }
    private int pestañaActiva = 1;
    private static readonly string[] NombresActividades = ["Pádel", "Fútbol", "Vóley", "Básquet"];
    private static readonly string[] DiasSemanaCortos = ["Lu", "Ma", "Mi", "Ju", "Vi", "Sa", "Do"];

    private DayOfWeek diaSemana = new DayOfWeek();
    private List<Actividad> actividades = [];
    private string SeleccionActividad = "";
    private bool mostrarCalendarioMini;
    private bool mostrarCalendarioCompleto;

    private DateOnly ReferenciaMes = new(DateTime.Today.Year, DateTime.Today.Month, 1);

    private void MesAnterior()
    {
        var mesActual = new DateOnly(DateTime.Today.Year, DateTime.Today.Month, 1);

        if (ReferenciaMes > mesActual)
            ReferenciaMes = ReferenciaMes.AddMonths(-1);
    }

    private void MesSiguiente()
    {
        ReferenciaMes = ReferenciaMes.AddMonths(1);
    }

    private bool EsMesActual()
    {
        return ReferenciaMes.Year == DateTime.Today.Year &&
               ReferenciaMes.Month == DateTime.Today.Month;
    }

    string mensaje = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (UsuarioSesion.UsuarioActual is null)
            {
                Navegador.NavigateTo("/Login");
                return;
            }

            var resultado = await ListarActividadesUseCase.ejecutar();
            actividades = resultado.ToList();

            if (!actividades.Any())
            {
                mensaje = "No hay actividades en la base de datos.";
            }
        }
        catch (Exception ex)
        {
            mensaje = "Error de sistema: " + ex.Message;
        }
    }

    private void AlActividadCambiada()
    {
        mostrarCalendarioCompleto = false;
        mostrarCalendarioMini = false;
    }

    private void AlternarCalendarioCompleto() => mostrarCalendarioCompleto = !mostrarCalendarioCompleto;

    private void MostrarCalendarioMini() => mostrarCalendarioMini = true;

    private void OcultarCalendarioMini() => mostrarCalendarioMini = false;

    private string TituloMes(DateOnly primerDia)
    {
        var dt = new DateTime(primerDia.Year, primerDia.Month, 1);
        return dt.ToString("MMMM yyyy", new CultureInfo("es-AR"));
    }

    private IReadOnlyList<DateOnly?> CeldasMes()
    {
        var primerDiaMes = ReferenciaMes;
        var primer = new DateTime(primerDiaMes.Year, primerDiaMes.Month, 1);
        var offset = ((int)primer.DayOfWeek + 6) % 7;
        var diasEnMes = DateTime.DaysInMonth(primerDiaMes.Year, primerDiaMes.Month);
        var lista = new List<DateOnly?>();
        for (var i = 0; i < offset; i++)
            lista.Add(null);
        for (var d = 1; d <= diasEnMes; d++)
            lista.Add(new DateOnly(primerDiaMes.Year, primerDiaMes.Month, d));
        return lista;
    }

    private bool DiaHabilitado(DateOnly dia)
    {
        var hoy = DateOnly.FromDateTime(DateTime.Today);
        return dia >= hoy && dia.Year == ReferenciaMes.Year && dia.Month == ReferenciaMes.Month;
    }

    private void IrADia(int actividadId, DateOnly fecha)
    {
        if (actividadId <= 0 || !DiaHabilitado(fecha))
            return;
        var f = fecha.ToString("yyyy-MM-dd");
        Navegador.NavigateTo($"/Turnos/dia?actividadId={actividadId}&fecha={f}");
    }

    private void IrAActividad(int actividadId, DayOfWeek diaSemana)
    {
        Navegador.NavigateTo($"/Turno/adelantada?actividadId={actividadId}&diaSemana={(int)diaSemana}");
    }

    private RenderFragment TablaCalendario(bool esMini, int actividadParaNavegar) => __builder =>
    {
        var celdas = CeldasMes();
        var claseTabla = esMini ? "table table-sm table-bordered mb-0" : "table table-bordered";

        __builder.OpenElement(0, "table");
        __builder.AddAttribute(1, "class", claseTabla);

        __builder.OpenElement(2, "thead");
        __builder.OpenElement(3, "tr");
        foreach (var d in DiasSemanaCortos)
        {
            __builder.OpenElement(4, "th");
            __builder.AddContent(5, d);
            __builder.CloseElement();
        }
        __builder.CloseElement();
        __builder.CloseElement();

        __builder.OpenElement(6, "tbody");
        for (var i = 0; i < celdas.Count; i += 7)
        {
            __builder.OpenElement(7, "tr");
            for (var j = 0; j < 7; j++)
            {
                var idx = i + j;
                __builder.OpenElement(8, "td");
                if (idx < celdas.Count && celdas[idx] is { } diaCelda)
                {
                    if (DiaHabilitado(diaCelda))
                    {
                        var captAccion = diaCelda;
                        __builder.OpenElement(9, "button");
                        __builder.AddAttribute(10, "type", "button");
                        __builder.AddAttribute(11, "class", "btn btn-link p-0");
                        __builder.AddAttribute(12, "onclick",
                            EventCallback.Factory.Create(this, () => IrADia(actividadParaNavegar, captAccion)));
                        __builder.AddContent(13, captAccion.Day);
                        __builder.CloseElement();
                    }
                    else
                    {
                        __builder.AddContent(14, diaCelda.Day);
                    }
                }
                __builder.CloseElement();
            }
            __builder.CloseElement();
        }
        __builder.CloseElement();

        __builder.CloseElement();
    };

}