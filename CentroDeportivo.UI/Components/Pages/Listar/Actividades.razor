@page "/Actividades"
@rendermode InteractiveServer
@inject CrearActividadUseCase CrearActividadUseCase
@inject ListarActividadesUseCase ListarActividadesUseCase
@inject EliminarActividadUseCase EliminarActividadUseCase
@inject IActividadRepositorio RepositorioActividad
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador

<PageTitle>Actividades</PageTitle>

@if (!(UsuarioSesion.EstaAutenticado() && (UsuarioSesion.esAdministrador() || UsuarioSesion.esEmpleado())))
{
    <div class="alert alert-warning">No tenés acceso. <NavLink href="/Login">Iniciar sesión</NavLink></div>
}
else
{
    <div class="container-fluid p-0">
        <h2 class="mb-1">Actividades</h2>
        <p class="text-muted mb-4">Bienvenido, @UsuarioSesion.UsuarioActual!.Nombre</p>

        <div class="d-flex gap-2 mb-4">
            <button class="btn btn-success" @onclick="CrearActividad">Crear actividad</button>
            <button class="btn btn-danger" @onclick="CerrarSesion">Cerrar sesión</button>
        </div>

        @if (quiereAgregar)
        {
            <div class="card shadow-sm mb-4" style="max-width: 500px;">
                <div class="card-body">
                    <h4 class="card-title mb-3">Datos de la actividad</h4>
                    <input placeholder="Nombre de actividad" @bind="act.nombre" class="form-control mb-2" />
                    <input placeholder="Descripción" @bind="act.descripcion" class="form-control mb-2" />
                    <input placeholder="Precio" @bind="act.precio" type="number" class="form-control mb-3" />
                    
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary flex-grow-1" @onclick="Aceptar">Aceptar</button>
                        <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </div>
            </div>
        }

        <div class="table-responsive shadow-sm" style="background: white; border-radius: 8px;">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Precio</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (actividad.Any()){
                        @foreach (var a in actividad)
                        {
                            <tr>
                                <td>@a.Id</td>
                                <td class="fw-bold">@a.Nombre</td>
                                <td>@a.Descripcion</td>
                                <td>$@a.Precio</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-primary" @onclick="() => Editar(a.Id)">Editar</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => ConfirmarEliminacion(a.Id)">Eliminar</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">No hay actividades registradas.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
<div>
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert alert-info mt-3">@mensaje</div>
    }
</div>

@if (mostrarDialog)
{
    <div class="modal show d-block shadow" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                </div>
                <div class="modal-body">
                    <p>¿Estás seguro de que querés eliminar esta actividad?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => mostrarDialog = false">Cancelar</button>
                    <button class="btn btn-danger" @onclick="Eliminar">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    string mensaje = "";
    bool mostrarDialog = false;
    int idAEliminar;
    bool quiereAgregar = false;
    Datos act = new Datos();

    List<Actividad> actividad = new List<Actividad>();

    protected override async Task OnInitializedAsync() {
        actividad = (await ListarActividadesUseCase.ejecutar()).ToList();
    }

    void CerrarSesion() { UsuarioSesion.CerrarSesion(); UsuarioSesion.NotificarCambio(); Navegador.NavigateTo("/Login", true); }
    void CrearActividad() => quiereAgregar = true;
    public void Editar(int Id) => Navegador.NavigateTo($"/editar-actividad/{Id}");
    void ConfirmarEliminacion(int Id) { idAEliminar = Id; mostrarDialog = true; }

    async Task Eliminar()
    {
        mensaje = "";
        mostrarDialog = false;
        try
        {
            await EliminarActividadUseCase.Ejecutar(idAEliminar);
            actividad = (await ListarActividadesUseCase.ejecutar()).ToList();
            mensaje = "La actividad se ha eliminado con exito.";
            mensaje = "";
            StateHasChanged();
        }
        catch (Exception ex) { mensaje = ex.Message; }
    }

    async Task Aceptar()
    {
        mensaje = "";
        try
        {
            var acti = new Actividad(act.nombre, act.descripcion, act.precio ?? 0);
            await CrearActividadUseCase.ejecutar(acti);
            actividad = (await ListarActividadesUseCase.ejecutar()).ToList();
            mensaje = "Actividad creada con exito.";
            act = new Datos();
            quiereAgregar = false;
            mensaje = "";
            StateHasChanged();
        }
        catch (Exception ex) { mensaje = ex.Message; }
    }

    void Cancelar() { quiereAgregar = false; mensaje = ""; act = new Datos(); }

    public class Datos
    {
        public string nombre { get; set; } = "";
        public string descripcion { get; set; } = "";
        public decimal? precio { get; set; }
    }
}