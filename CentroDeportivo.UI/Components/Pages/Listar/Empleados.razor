@page "/Empleados"
@rendermode InteractiveServer
@inject CrearEmpleadoUseCase CrearEmpleadoUseCase
@inject ListarEmpleadosUseCase ListarEmpleadosUseCase
@inject EliminarEmpleadoUseCase EliminarEmpleadoUseCase
@inject IUsuarioRepositorio RepositorioUsuario
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador

<PageTitle>Empleados</PageTitle>

@if (!(UsuarioSesion.EstaAutenticado() && (UsuarioSesion.esAdministrador())))
{
    <div class="alert alert-warning">¡No tenés acceso a esta seccion!</div>
}
else
{
    <div class="container-fluid p-0">
        <h2 class="mb-1">Gestión de Empleados</h2>
        <p class="text-muted mb-4">Bienvenido, @UsuarioSesion.UsuarioActual!.Nombre</p>

        <div class="d-flex gap-2 mb-4">
            <button class="btn btn-success" @onclick="CrearEmpleado">Registrar empleado</button>
            <button class="btn btn-danger" @onclick="CerrarSesion">Cerrar sesión</button>
        </div>

        @if (quiereAgregar)
        {
            <div class="card shadow-sm mb-4" style="max-width: 500px;">
                <div class="card-body">
                    <h4 class="card-title mb-3">Datos del empleado</h4>
                    <input placeholder="Nombre" @bind="emp.nombre" class="form-control mb-3" />
                    <input placeholder="Apellido" @bind="emp.apellido" class="form-control mb-3" />
                    <input placeholder="DNI" @bind="emp.dni" class="form-control mb-3" />
                    <input placeholder="Email" @bind="emp.email" class="form-control mb-3" />
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-primary flex-grow-1" @onclick="Aceptar">Guardar</button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(mensaje))
        {
            <div class="alert alert-info alert-dismissible fade show mb-4" role="alert">
                @mensaje
            </div>
        }

        <div class="table-responsive shadow-sm" style="background: white; border-radius: 8px;">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th>DNI</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in empleado)
                    {
                        <tr>
                            <td>@e.Id</td>
                            <td>@e.Nombre</td>
                            <td>@e.Apellido</td>
                            <td>@e.Dni</td>
                            <td class="text-center">                               
                                <button class="btn btn-sm btn-danger" @onclick="() => ConfirmarEliminacion(e.Id)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (mostrarDialog)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white"><h5>Confirmar</h5></div>
                <div class="modal-body"><p>¿Eliminar empleado definitivamente?</p></div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => mostrarDialog = false">No</button>
                    <button class="btn btn-danger" @onclick="Eliminar">Sí, eliminar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    string mensaje = ""; bool mostrarDialog = false; int idAEliminar; bool quiereAgregar = false; Datos emp = new Datos();
    List<Usuario> empleado = new List<Usuario>();

    protected override async Task OnInitializedAsync() => empleado = (await ListarEmpleadosUseCase.ejecutar()).ToList();
    
    void CerrarSesion() { UsuarioSesion.CerrarSesion(); Navegador.NavigateTo("/Login", true); }
    
    void CrearEmpleado()
    {
        emp = new Datos(); 
        quiereAgregar = true;
        mensaje = "";
    }
    
    
    
    void ConfirmarEliminacion(int Id) { idAEliminar = Id; mostrarDialog = true; }

    async Task Eliminar()
    {
        mostrarDialog = false;
        try
        {
            await EliminarEmpleadoUseCase.ejecutar(idAEliminar);
            empleado = (await ListarEmpleadosUseCase.ejecutar()).ToList();
            mensaje = "Empleado eliminado.";
        }
        catch (Exception ex) { mensaje = ex.Message; }
        StateHasChanged();
    }

    async Task Aceptar()
    {
        try
        {

            var emple = new Usuario(emp.nombre, emp.apellido, "a", emp.dni, "A123456789", emp.email, false, Rol.Empleado);
            
            await CrearEmpleadoUseCase.ejecutar(emple);
            
            empleado = (await ListarEmpleadosUseCase.ejecutar()).ToList();
            
            mensaje = "Empleado creado exitosamente.";
            quiereAgregar = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            mensaje = "Error: " + ex.Message;
            StateHasChanged();
        }
    }

    void Cancelar() { quiereAgregar = false; mensaje = ""; }

    public class Datos
    {
        public string email { get; set; } = "";
        public string nombre { get; set; } = "";
        public string apellido { get; set; } = "";
        public string dni { get; set; } = "";
    }
}