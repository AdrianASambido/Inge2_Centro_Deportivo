@page "/Turnos/dia"
@rendermode InteractiveServer
@using System.Globalization
@using CentroDeportivo.Aplicacion.Entidades
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador
@inject ListarTurnosCalendarioUseCase ListarTurnosCalendarioUseCase
@inject ObtenerActividadPorId ObtenerActividadPorId
@inject ObtenerUsuarioPorId ObtenerUsuarioPorId
@inject IJSRuntime JS
@inject CrearReservaUseCase CrearReservaUseCase
@inject UnirseListaDeEsperaUseCase UnirseListaDeEsperaUseCase
@inject IniciarReservaOcasionalUseCase iniciarReservaOcasionalUse
@inject ConsultarCreditosUseCase ConsultarCreditosUseCase
@inject CrearReservaConCreditoUseCase CrearReservaConCreditoUseCase

<PageTitle>Horarios del día</PageTitle>

@if (!_inicializado)
{
    <div class="d-flex justify-content-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (UsuarioSesion.UsuarioActual is null)
{
    <div class="alert alert-warning">
        Debe iniciar sesión. <NavLink href="/Login">Ir al Login</NavLink>
    </div>
}
else if (!parametrosOk)
{
    <div class="container-fluid p-0">
        <div class="alert alert-warning">Indique actividad y fecha válida.</div>
        <button type="button" class="btn btn-secondary" @onclick="VolverTurnos">Volver</button>
    </div>
}
else
{
    <div class="container-fluid p-0">
        <h2 class="mb-1">@actividadNombre</h2>
        <p class="text-muted mb-4">
            Día: @fechaFormateada
        </p>

        @if (!string.IsNullOrEmpty(mensajeExito))
        {
            <div class="alert alert-success shadow-sm">@mensajeExito</div>
        }
        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="alert alert-danger shadow-sm">@mensajeError</div>
        }

        <div class="row">
            <div class="col-12 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white fw-bold">Turnos Disponibles</div>
                    <ul class="list-group list-group-flush">
                        @if (turnosFiltrados.Any())
                        {
                            @foreach (var t in turnosFiltrados)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fw-bold">@t.HoraInicio.ToString("HH:mm") – @t.HoraFin.ToString("HH:mm")</span>
                                        <div class="small d-block text-muted">
                                            @if (t.CupoDisponible == 0)
                                            {
                                                <span class="text-danger">Completo</span>
                                            }
                                            else
                                            {
                                                <span>Libres: @t.CupoDisponible / @t.CupoMaximo</span>
                                            }
                                        </div>
                                        <div class="small d-block text-muted">Precio: $@t.PrecioTurno</div>
                                    </div>
                                    <div>
                                        @if (t.CupoDisponible == 0)
                                        {
                                            <button type="button" class="btn btn-sm btn-warning"
                                                    disabled="@procesando"
                                                    @onclick="() => UnirseListaEspera(t.Id)">
                                                Unirse a lista de espera
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-success"
                                                    disabled="@procesando"
                                                    @onclick="() => ConsultarCreditos(t.Id)">
                                                Reservar
                                            </button>
                                        }
                                    </div>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-center py-4 text-muted">
                                No hay turnos disponibles para reservar en esta fecha.
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <button type="button" class="btn btn-secondary mt-2" @onclick="VolverTurnos">Volver a turnos</button>
    </div>
}

@if (mostrarDialogoReserva)
{
    <div class="modal show d-block shadow" tabindex="-1" style="background: rgba(25,25,100,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Reserva con créditos</h5>
                </div>
                <div class="modal-body">
                    <p>¿Desea utilizar un crédito disponible para la actividad <strong>@actividadNombre</strong> en esta reserva?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => Reservar(idTurnoAReservar)">No</button>
                    <button class="btn btn-success" @onclick="() => ReservarConCredito(idTurnoAReservar)">Si</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery] public int? ActividadId { get; set; }
    [SupplyParameterFromQuery] public string? Fecha { get; set; }
    [SupplyParameterFromQuery] public bool pagoExitoso { get; set; }
    [SupplyParameterFromQuery] public bool volviMP { get; set; }
    [SupplyParameterFromQuery(Name = "payment_id")] public string? PaymentId { get; set; }
    [SupplyParameterFromQuery] public int TurnoId { get; set; }
    [SupplyParameterFromQuery] public int? UserId { get; set; }

    private List<Credito> creditosUsuario = new();
    private bool parametrosOk;
    private DateOnly? fechaElegida;
    private string fechaFormateada = "";
    private string actividadNombre = "";
    private bool procesando;
    private string? mensajeExito;
    private string? mensajeError;
    private string? tokenTarjeta;

    private List<Turno> turnosFiltrados = new();
    private bool _inicializado = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && volviMP)
        {
            if (UsuarioSesion.UsuarioActual is null && UserId.HasValue)
            {
                var usuario = await ObtenerUsuarioPorId.Ejecutar(UserId.Value);
                if (usuario != null)
                {
                    UsuarioSesion.RestaurarSesion(usuario);
                    await UsuarioSesion.NotificarCambio();
                }
            }

            await ProcesarVueltaDeMP();
            StateHasChanged();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // siempre parseamos los parámetros de fecha y actividad si vienen
        if (ActividadId is > 0 && !string.IsNullOrWhiteSpace(Fecha)
            && DateOnly.TryParse(Fecha, CultureInfo.InvariantCulture, out var fp))
        {
            parametrosOk = true;
            fechaElegida = fp;
            fechaFormateada = fechaElegida.Value.ToString("dddd d MMMM yyyy", new CultureInfo("es-AR"));
        }

        if (UsuarioSesion.UsuarioActual is null) return;
        if (volviMP) return; // lo maneja OnAfterRenderAsync

        var todosLosCreditos = await ConsultarCreditosUseCase.Ejecutar(UsuarioSesion.UsuarioActual!.Id);
        creditosUsuario = todosLosCreditos
            .Where(c => c.Id_Actividad == ActividadId) 
            .ToList();
        procesando = true;
        mensajeError = mensajeExito = null;

        if (!parametrosOk)
        {
            procesando = false;
            return;
        }

        try
        {
            var act = await ObtenerActividadPorId.Ejecutar(ActividadId!.Value);
            actividadNombre = act?.Nombre ?? "Actividad";
            await CargarTurnos();
        }
        catch (Exception ex)
        {
            mensajeError = "Error de carga: " + ex.Message;
        }
        finally
        {
            procesando = false;
        }
    }

    private async Task ProcesarVueltaDeMP()
    {
        if (!volviMP) return;

        Console.WriteLine("Payment recibido:");
        Console.WriteLine(PaymentId);
        Console.WriteLine(Navegador.Uri);

        // cargar nombre de actividad para que la vista lo muestre
        if (ActividadId.HasValue)
        {
            var act = await ObtenerActividadPorId.Ejecutar(ActividadId.Value);
            actividadNombre = act?.Nombre ?? "Actividad";
        }

        if (pagoExitoso)
        {
            var nuevaReserva = new Reserva()
            {
                Id_Usuario = UsuarioSesion.UsuarioActual!.Id,
                Id_Turno = TurnoId
            };
            await CrearReservaUseCase.Ejecutar(nuevaReserva, PaymentId);
            mensajeExito = "Reserva realizada con éxito.";
            await CargarTurnos();
        }
        else
        {
            mensajeError = "El pago no se pudo realizar. Intente nuevamente.";
            await CargarTurnos();
        }
    }

    private async Task CargarTurnos()
    {
        if (!parametrosOk || fechaElegida is null || ActividadId is null) return;

        var idUsuario = UsuarioSesion.UsuarioActual!.Id;


        var todos = await ListarTurnosCalendarioUseCase.ejecutar(idUsuario, fechaElegida.Value, ActividadId.Value);

        var ahora = DateTime.Now;
        var fechaHoy = DateOnly.FromDateTime(ahora);
        var horaActual = TimeOnly.FromDateTime(ahora);


        turnosFiltrados = todos
            .Where(t => t.Estado != EstadoTurno.Cancelado
                     && (t.Fecha > fechaHoy || (t.Fecha == fechaHoy && t.HoraInicio > horaActual)))
            .OrderBy(t => t.HoraInicio)
            .ToList();
    }
    private async Task UnirseListaEspera(int turnoId)
    {
        procesando = true;
        mensajeError = mensajeExito = null;
        try
        {
            await UnirseListaDeEsperaUseCase.Ejecutar(UsuarioSesion.UsuarioActual.Id, turnoId);
            mensajeExito = "Usted se ha unido a la lista de espera correctamente.";
            await CargarTurnos();
        }
        catch (Exception ex)
        {
            mensajeError = ex.Message;
        }
        finally
        {
            procesando = false;
            StateHasChanged();
        }
    }

    private async Task Reservar(int turnoId)
    {
        mostrarDialogoReserva = false;
        procesando = true;
        mensajeError = mensajeExito = null;
        try
        {

            var nuevaReserva = new Reserva()
            {
                Id_Usuario = UsuarioSesion.UsuarioActual!.Id,
                Id_Turno = turnoId
            };


            string urlPagoMercadoPago = await iniciarReservaOcasionalUse.Ejecutar(nuevaReserva);

            Navegador.NavigateTo(urlPagoMercadoPago, forceLoad: true);
        }
        catch (Exception ex)
        {
            mensajeError = ex.Message;
            procesando = false;
            StateHasChanged();
        }
    }

    private async Task ReservarConCredito(int turnoId)
    {
        procesando = true;
        mensajeError = mensajeExito = null;
        try
        {

            var nuevaReserva = new Reserva()
            {
                Id_Usuario = UsuarioSesion.UsuarioActual!.Id,
                Id_Turno = turnoId
            };

            await CrearReservaConCreditoUseCase.Ejecutar(nuevaReserva);
            mensajeExito = "Reserva realizada con éxito utilizando un crédito.";
            mostrarDialogoReserva = false;
            await CargarTurnos();
        }
        catch (Exception ex)
        {
            mensajeError = ex.Message;
            procesando = false;
            StateHasChanged();
        }
    }

    public bool mostrarDialogoReserva { get; set; } = false;
    public int idTurnoAReservar { get; set; }

    public void ConsultarCreditos(int Id)
    {
        idTurnoAReservar = Id;
        if (creditosUsuario.Any())
        {
            mostrarDialogoReserva = true;
        }
        else
        {
            Reservar(Id);
        }
    }

    private void VolverTurnos() => Navegador.NavigateTo("/Turnos");
}