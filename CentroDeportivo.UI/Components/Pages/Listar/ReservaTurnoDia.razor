@page "/Turnos/dia"
@rendermode InteractiveServer
@using System.Globalization
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador
@inject ListarTurnosUseCase ListarTurnosUseCase 
@inject IActividadRepositorio ActividadRepositorio
@inject CrearReservaUseCase CrearReservaUseCase

<PageTitle>Horarios del día</PageTitle>

@if (UsuarioSesion.UsuarioActual is null)
{
    <div class="alert alert-warning">Debe iniciar sesión. <NavLink href="/Login">Ir al Login</NavLink></div>
}
else if (!parametrosOk)
{
    <div class="container-fluid p-0">
        <div class="alert alert-warning">Indique actividad y fecha válida.</div>
        <button type="button" class="btn btn-secondary" @onclick="VolverTurnos">Volver</button>
    </div>
}
else
{
    <div class="container-fluid p-0">
        <h2 class="mb-1">@actividadNombre</h2>
        <p class="text-muted mb-4">
            Día: @fechaFormateada
        </p>

                @if (!string.IsNullOrEmpty(mensajeExito))
                {
                    <div class="alert alert-success">@mensajeExito</div>
                }
                @if (!string.IsNullOrEmpty(mensajeError))
                {
                    <div class="alert alert-danger">@mensajeError</div>
                }
                <p class="small text-muted mb-3">
                    Horarios de 16:00 a 22:00. Verde: hay cupo libre. Gris: cupo completo.
                </p>

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-light fw-bold">Bloques 16:00–19:00</div>
                    <ul class="list-group list-group-flush">
                        @foreach (var t in turnosTarde)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center @(t.CupoDisponible > 0 ? "" : "bg-light text-muted")">
                                <div>
                                    @t.HoraInicio.ToString("HH:mm") – @t.HoraFin.ToString("HH:mm")
                                    <div class="small d-block text-muted">Libres: @t.CupoDisponible / @t.CupoMaximo</div>
                                </div>
                                @if (t.CupoDisponible > 0 && t.Estado != EstadoTurno.Cancelado)
                                {
                                    <button type="button" class="btn btn-sm btn-success" disabled="@procesando" @onclick="() => Reservar(t.Id)">
                                        Reservar
                                    </button>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Completo</span>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-light fw-bold">Bloques 20:00–22:00</div>
                    <ul class="list-group list-group-flush">
                        @foreach (var t in turnosNoche)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center @(t.CupoDisponible > 0 ? "" : "bg-light text-muted")">
                                <div>
                                    @t.HoraInicio.ToString("HH:mm") – @t.HoraFin.ToString("HH:mm")
                                    <div class="small d-block text-muted">Libres: @t.CupoDisponible / @t.CupoMaximo</div>
                                </div>
                                @if (t.CupoDisponible > 0 && t.Estado != EstadoTurno.Cancelado)
                                {
                                    <button type="button" class="btn btn-sm btn-success" disabled="@procesando" @onclick="() => Reservar(t.Id)">
                                        Reservar
                                    </button>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Completo</span>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <button type="button" class="btn btn-secondary mt-2" @onclick="VolverTurnos">Volver a turnos</button>
    </div>
}

@code {
    [SupplyParameterFromQuery] public int? ActividadId { get; set; }
    [SupplyParameterFromQuery] public string? Fecha { get; set; }

    private bool parametrosOk;
    private DateOnly? fechaElegida;
    private string fechaFormateada = "";
    private string actividadNombre = "";
    private IReadOnlyList<Turno> turnos = [];
    private bool procesando;
    private string? mensajeExito;
    private string? mensajeError;

    private RenderFragment FilaTurno(Turno t) => __builder =>
    {
        var hayCupo = t.CupoDisponible > 0 && t.Estado != EstadoTurno.Cancelado;
        __builder.OpenElement(0, "li");
        __builder.AddAttribute(1, "class", "list-group-item " + (hayCupo ? "list-group-item-success" : "list-group-item-secondary"));

        __builder.OpenElement(2, "div");
        __builder.AddAttribute(3, "class", "d-flex justify-content-between align-items-center");
        __builder.AddContent(4, $"{t.HoraInicio:HH:mm} – {t.HoraFin:HH:mm}");
        __builder.OpenElement(5, "span");
        __builder.AddAttribute(6, "class", "small");
        __builder.AddContent(7, $"Cupos libres: {t.CupoDisponible} / {t.CupoMaximo}");
        __builder.CloseElement();
        __builder.CloseElement();

        if (hayCupo)
        {
            var idCapt = t.Id;
            __builder.OpenElement(8, "button");
            __builder.AddAttribute(9, "type", "button");
            __builder.AddAttribute(10, "class", "btn btn-sm btn-primary mt-2");
            __builder.AddAttribute(11, "disabled", procesando);
            __builder.AddAttribute(12, "onclick", EventCallback.Factory.Create(this, () => Reservar(idCapt)));
            __builder.AddContent(13, "Seleccionar horario");
            __builder.CloseElement();
        }

        __builder.CloseElement();
    };

    protected override async Task OnParametersSetAsync()
    {
        mensajeError = mensajeExito = null;

        if (UsuarioSesion.UsuarioActual is null) return;

        if (ActividadId is not > 0 || string.IsNullOrWhiteSpace(Fecha) || !DateOnly.TryParse(Fecha, CultureInfo.InvariantCulture, out var fp))
        {
            parametrosOk = false;
            procesando = false;
            return;
        }

        parametrosOk = true;
        fechaElegida = fp;

        var act = await ActividadRepositorio.ObtenerPorIdAsync(ActividadId!.Value);
        actividadNombre = act?.Nombre ?? "Actividad";

        await CargarTurnos();
    }

    private async Task CargarTurnos()
    {
        if (!parametrosOk || fechaElegida is null || ActividadId is null || UsuarioSesion.UsuarioActual is null)
            return;

        turnos = (await ListarTurnosUseCase.Ejecutar(fechaElegida.Value, ActividadId.Value, null, null, null)).ToList();
    }

    private async Task Reservar(int turnoId)
    {
        procesando = true;
        mensajeError = mensajeExito = null;
        try
        {
            var uid = UsuarioSesion.UsuarioActual!.Id;
            var (ok, msg, _) = await CrearReservaUseCase.ejecutar(uid, turnoId);
            if (ok)
                mensajeExito = "Reserva exitosa";
            else
                mensajeError = msg;

            await CargarTurnos();
        }
        catch (Exception ex)
        {
            mensajeError = ex.Message;
        }
        finally
        {
            procesando = false;
            StateHasChanged();
        }
    }

    private void VolverTurnos() => Navegador.NavigateTo("/Turnos");
}