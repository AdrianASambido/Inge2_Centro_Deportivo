@page "/listar-turnos-creados"
@using BlazorBarcodeScanner.ZXing.JS
@using System.Globalization
@inject Sesion UsuarioSesion
@inject ListarTurnosUseCase ListarTurnosUseCase
@rendermode InteractiveServer
@inject NavigationManager Navegador
@inject ITurnoRepositorio TurnoRepositorio
@inject EliminarTurnoUseCase EliminarTurnoUseCase
@inject CrearTurnoUseCase CrearTurnoUseCase
@inject ConsultarDisponibilidadUseCase ConsultarDisponibilidadUseCase
@inject ListarActividadesUseCase ListarActividadesUseCase
@inject ListarInscriptosUseCase ListarInscriptosUseCase
@inject RegistrarAsistenciaManualUseCase RegistrarAsistenciaManualUseCase
@inject ConfirmarPagoReservaUseCase ConfirmarPagoReservaUseCase
@inject RegistrarAsistenciaQrUseCase RegistrarAsistenciaQrUseCase
@inject ListarProfesoresUseCase ListarProfesoresUseCase
@inject ListarCanchasUseCase ListarCanchasUseCase

<PageTitle>Listado de Turnos</PageTitle>

@if (!(UsuarioSesion.EstaAutenticado()) && (UsuarioSesion.esAdministrador() || UsuarioSesion.esEmpleado()))
{
    <div class="alert alert-warning">¡No tenés acceso a esta seccion!</div>
}
else
{
    <div class="container-fluid p-0">
        <h2 class="mb-1">Turnos creados</h2>
        <p class="text-muted mb-4">Bienvenido, @UsuarioSesion.UsuarioActual!.Nombre</p>

        <div class="d-flex gap-2 mb-4">
            <button class="btn btn-success" @onclick="CrearTurno">
                <i class="bi bi-plus-circle"></i> Programar turno
            </button>
            <button class="btn btn-danger" @onclick="CerrarSesion">
                Cerrar sesión
            </button>
        </div>

        @if (quiereAgregar)
        {
            @if (!string.IsNullOrEmpty(mensaje))
            {
                <div class="alert alert-info mt-3 shadow-sm">@mensaje</div>
            }

            <div class="card shadow-sm mb-4 border-primary" style="max-width: 600px;">
                <div class="card-body">
                    <h4 class="card-title mb-3">Datos sobre el turno</h4>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha</label>
                            <input type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" @bind="t.Fecha" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Hora inicio</label>
                            <input type="time" class="form-control" @bind="t.HoraInicio" />
                        </div>
                    </div>

                    <button class="btn btn-primary w-100 mb-3" @onclick="BuscarPorDisponibilidad">Buscar disponibilidad</button>
                    <button class="btn btn-secondary mb-3" @onclick="Cancelar">Cancelar</button>

                    @if (mostrarDisponibles)
                    {
                        <div class="fade-in">
                            <div class="mb-3">
                                <label class="form-label">Cancha</label>
                                <select @bind="t.Id_Cancha" class="form-select">
                                    <option value="">Seleccione una cancha</option>
                                    @foreach (var c in canchasDispo)
                                    {
                                        <option value="@c.Id">Cancha @c.Numero </option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Profesor</label>
                                <select @bind="t.Id_Profesor" class="form-select">
                                    <option value="">Seleccione un profesor</option>
                                    @foreach (var p in profesoresDispo)
                                    {
                                        <option value="@p.Id"> @p.Nombre </option>
                                    }
                                </select>
                            </div>

                            @if (canchaSeleccionada != null)
                            {
                                <div class="mb-3">
                                    <label class="form-label">Cupo máximo (Capacidad: @canchaSeleccionada.Capacidad)</label>
                                    <select @bind="t.CupoMaximo" class="form-select">
                                        @for (int i = 1; i <= canchaSeleccionada.Capacidad; i++)
                                        {
                                            <option value="@i">@i</option>
                                        }
                                    </select>
                                </div>
                            }

                            <div class="mb-3">
                                <label class="form-label">Actividad</label>
                                <select @bind="t.Id_Actividad" class="form-select">
                                    <option value="">Seleccione una actividad</option>
                                    @foreach (var a in actividades)
                                    {
                                        <option value="@a.Id">@a.Nombre</option>
                                    }
                                </select>
                            </div>

                            <div class="d-flex gap-2">
                                <button class="btn btn-primary flex-grow-1" @onclick="Aceptar">Confirmar Turno</button>
                                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label small fw-bold">Actividad</label>
                        <select class="form-select" @bind="filtroActividadId">
                            <option value="0">Todas</option>
                            @foreach (var a in actividades)
                            {
                                <option value="@a.Id">@a.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-bold">Cancha</label>
                        <select class="form-select" @bind="filtroCanchaId">
                            <option value="0">Todas</option>
                            @foreach (var c in todasLasCanchas)
                            {
                                <option value="@c.Id">Cancha @c.Numero</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-bold">Profesor</label>
                        <select class="form-select" @bind="filtroProfesorId">
                            <option value="0">Todos</option>
                            @foreach (var p in todosLosProfesores)
                            {
                                <option value="@p.Id">@p.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-bold">Fecha</label>
                        <input type="date" class="form-control" @bind="filtroFecha" />
                    </div>
                    <div class="col-md-4 d-flex gap-2">
                        <button class="btn btn-primary flex-grow-1" @onclick="AplicarFiltros">Aplicar filtros</button>
                        <button class="btn btn-outline-secondary" @onclick="LimpiarFiltros">Limpiar</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive shadow-sm" style="background: white; border-radius: 8px;">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Actividad</th>
                        <th>Profesor</th>
                        <th>Fecha</th>
                        <th>Hora inicio</th>
                        <th>Hora fin</th>
                        <th>Cancha</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (turnosFiltrados.Any())
                    {
                        @foreach (var t in turnosFiltrados)
                        {
                            <tr>
                                <td class="fw-bold">@t.Id</td>
                                <td>@t.Actividad.Nombre</td>
                                <td>@t.Profesor.Nombre</td>
                                <td>@t.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@t.HoraInicio</td>
                                <td>@t.HoraFin</td>
                                <td><span class="badge bg-info text-dark">N° @t.Cancha.Numero</span></td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => MostrarInscriptos(t.Id)">
                                        Ver Inscriptos
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">No se encontraron turnos con los filtros seleccionados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert alert-info mt-3 shadow-sm">@mensaje</div>
}

@if (mostrarInscriptos)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.3);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-yellow text-white"><h5>Incriptos</h5></div>
                <div class="modal-body">
                    <div class="table-responsive shadow-sm" style="background: white; border-radius: 8px;">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Nombre</th>
                                    <th>Apellido</th>
                                    <th>DNI</th>
                                    <th>Fecha</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in reservas)
                                {
                                    <tr>
                                        <td>@r.Usuario.Nombre</td>
                                        <td>@r.Usuario.Apellido</td>
                                        <td>@r.Usuario.Dni</td>
                                        <td>@t.Fecha.ToString("dd/MM/yyyy")</td>
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => RegistrarAsistencia(r.Id)">
                                                Registrar asistencia
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => RegistrarPago(r.Id)">Confirmar pago</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    @if (!string.IsNullOrEmpty(mensaje))
                    {
                        <div class="alert alert-info mt-3 shadow-sm">@mensaje</div>
                    }
                    <button class="btn btn-secondary" @onclick="() => mostrarInscriptos = false">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

<div class="mt-4">
    <button class="btn btn-warning w-50 mb-3" @onclick=" () => mostrarEscanner = true"><i class="bi bi-qr-code-scan"></i> Escanear QR</button>
</div>

@if (mostrarEscanner)
{
    <div class="card shadow-sm mb-4 border-info" style="max-width: 300px;">
        <div class="card-body text-center">
            <h5 class="card-title">Escaneando QR...</h5>
            <div class="bg-dark rounded p-2 mb-3">
                <BlazorBarcodeScanner.ZXing.JS.BarcodeReader OnBarcodeReceived="@(args => ProcesarQREscaneado(args.BarcodeText))" @ref="lector" />
            </div>
            <button class="btn btn-secondary btn-sm" @onclick="() => mostrarEscanner = false">Cancelar escaneo</button>
        </div>
    </div>
}

@code {
    bool mostrarEscanner = false;
    List<Reserva>? reservas = new List<Reserva>();
    bool mostrarInscriptos = false;
    bool mostrarDisponibles = false;
    bool quiereAgregar = false;
    string mensaje = "";
    Datos t = new Datos();

    private int filtroActividadId = 0;
    private int filtroCanchaId = 0;
    private int filtroProfesorId = 0;
    private DateTime? filtroFecha;

    private List<Profesor> todosLosProfesores = new();
    private List<Cancha> todasLasCanchas = new();
    private List<Profesor> profesoresDispo = new();
    private List<Actividad> actividades = new();
    private List<Cancha> canchasDispo = new();
    private List<Turno> turnos = new();
    private List<Turno> turnosFiltrados = new();

    Cancha? canchaSeleccionada => canchasDispo.FirstOrDefault(c => c.Id == t.Id_Cancha);

    protected override async Task OnInitializedAsync()
    {
        turnos = (await ListarTurnosUseCase.Ejecutar(null, null, null, null, null)).ToList();
        actividades = (await ListarActividadesUseCase.ejecutar()).ToList();
        todosLosProfesores = (await ListarProfesoresUseCase.ejecutar()).ToList();
        todasLasCanchas = (await ListarCanchasUseCase.ejecutar()).ToList();
        turnosFiltrados = turnos;
    }

    private void AplicarFiltros()
    {
        turnosFiltrados = turnos.Where(t =>
            (filtroActividadId == 0 || t.Id_Actividad == filtroActividadId) &&
            (filtroCanchaId == 0 || t.Id_Cancha == filtroCanchaId) &&
            (filtroProfesorId == 0 || t.Id_Profesor == filtroProfesorId) &&
            (!filtroFecha.HasValue || t.Fecha == DateOnly.FromDateTime(filtroFecha.Value))
        ).ToList();
    }

    private void LimpiarFiltros()
    {
        filtroActividadId = 0;
        filtroCanchaId = 0;
        filtroProfesorId = 0;
        filtroFecha = null;
        turnosFiltrados = turnos;
    }

    void CerrarSesion()
    {
        UsuarioSesion.CerrarSesion();
        Navegador.NavigateTo("/Login", true);
    }

    void CrearTurno() => quiereAgregar = true;

    async Task RegistrarPago(int idReserva)
    {
        try
        {
            mensaje = "";
            await ConfirmarPagoReservaUseCase.Ejecutar(idReserva);
            mensaje = "Pago confirmado correctamente.";
        }
        catch (Exception ex) { mensaje = ex.Message; }
    }

    async Task MostrarInscriptos(int Id)
    {
        try
        {
            mostrarInscriptos = true;
            reservas = (await ListarInscriptosUseCase.Ejecutar(Id)).ToList();
            mensaje = "";
        }
        catch (Exception ex)
        {
            mensaje = ex.Message;
            mostrarInscriptos = false;
        }
    }

    async Task RegistrarAsistencia(int idReserva)
    {
        try
        {
            mensaje = "";
            await RegistrarAsistenciaManualUseCase.Ejecutar(idReserva);
        }
        catch (Exception ex) { mensaje = ex.Message; }
    }

    async Task BuscarPorDisponibilidad()
    {
        try
        {
            mensaje = "";
            var (profesD, canchasD) = await ConsultarDisponibilidadUseCase.ejecutar(t.Fecha, t.HoraInicio);
            profesoresDispo = profesD.ToList();
            canchasDispo = canchasD.ToList();
            mostrarDisponibles = true;
        }
        catch (Exception ex)
        {
            mensaje = ex.Message;
            mostrarDisponibles = false;
        }
    }

    async Task Aceptar()
    {
        try
        {
            mensaje = "";
            var nuevoTurno = new Turno
            {
                Fecha = this.t.Fecha,
                HoraInicio = this.t.HoraInicio,
                HoraFin = this.t.HoraInicio.AddHours(1),
                CupoMaximo = this.t.CupoMaximo,
                Id_Actividad = this.t.Id_Actividad,
                Id_Profesor = this.t.Id_Profesor,
                Id_Cancha = this.t.Id_Cancha
            };
            await CrearTurnoUseCase.ejecutar(nuevoTurno);
            turnos = (await ListarTurnosUseCase.Ejecutar(null, null, null, null, null)).ToList();
            AplicarFiltros();
            mensaje = "Turno creado correctamente.";
            quiereAgregar = false;
        }
        catch (Exception ex) { mensaje = ex.Message; }
    }

    private BlazorBarcodeScanner.ZXing.JS.BarcodeReader lector;
    private async Task ProcesarQREscaneado(string codigo)
    {
        try
        {
            mensaje = "";
            // await RegistrarAsistenciaQrUseCase.Ejecutar(codigo);
            mensaje = "Asistencia registrada correctamente.";
            mostrarEscanner = false;
        }
        catch (Exception ex) { mensaje = ex.Message; }
    }

    void Cancelar()
    {
        quiereAgregar = false;
        mostrarDisponibles = false;
        t = new Datos();
    }

    public class Datos
    {
        public int Id { get; set; }
        public DateOnly Fecha { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public TimeOnly HoraInicio { get; set; } = TimeOnly.FromDateTime(DateTime.Now);
        public int CupoMaximo { get; set; }
        public int Id_Actividad { get; set; }
        public int Id_Profesor { get; set; }
        public int Id_Cancha { get; set; }
    }
}