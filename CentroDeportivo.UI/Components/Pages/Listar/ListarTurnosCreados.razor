                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-bold">Fecha</label>
                        <input type="date" class="form-control" @bind="filtroFecha" />
                    </div>
                    <div class="col-md-4 d-flex gap-2">
                        <button class="btn btn-primary flex-grow-1" @onclick="AplicarFiltros">Aplicar filtros</button>
                        <button class="btn btn-outline-secondary" @onclick="LimpiarFiltros">Limpiar</button>
                    </div>
                </div>
            </div>
        </div>
        *@
        <div class="table-responsive shadow-sm" style="background: white; border-radius: 8px;">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Actividad</th>
                        <th>Profesor</th>
                        <th>Fecha</th>
