        </div>
    </div>
}

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert alert-info mt-3 shadow-sm">@mensaje</div>
}

@if (mostrarInscriptos)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.3);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-yellow text-white"><h5>Incriptos</h5></div>
                <div class="modal-body">
                    <div class="table-responsive shadow-sm" style="background: white; border-radius: 8px;">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Nombre</th>
                                    <th>Apellido</th>
                                    <th>DNI</th>
                                    <th>Fecha</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in reservas)
                                {
                                    <tr>
                                        <td>@r?.Usuario?.Nombre</td>
                                        <td>@r?.Usuario?.Apellido</td>
                                        <td>@r?.Usuario?.Dni</td>
                                        <td>@t.Fecha.ToString("dd/MM/yyyy")</td>
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => RegistrarAsistencia(r.Id)" 
                                                disabled="@(!PuedeRegistrarAsistencia(r))">
                                                Registrar asistencia
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmarEliminacion(r.Id)"
                                                disabled="@(yaPasoLaHora(r))">Eliminar</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (!string.IsNullOrEmpty(mensajeTabla))
                        {
                            <div class="alert alert-info mt-3 shadow-sm">@mensajeTabla</div>
                        }

                        @if (mostrarDialog)
                        {
                            <div class="modal show d-block shadow" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Confirmar eliminación</h5>
                                        </div>
                                        <div class="modal-body">
                                            <p>¿Estás seguro de que querés eliminar este inscripto?</p>
                                        </div>
                                        <div class="modal-footer">
                                            <button class="btn btn-secondary" @onclick="() => mostrarDialog = false">Cancelar</button>
                                            <button class="btn btn-danger" @onclick="() => EliminarInscripto()">Confirmar</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => mostrarInscriptos = false">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

<button class="btn btn-info text-white mt-3" @onclick="AbrirEscaner">
    <i class="bi bi-qr-code-scan"></i> Escanear QR
</button>

@if (mostrarEscanner)
{
    <div class="modal show d-block" tabindex="-1" role="dialog" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-camera-fill me-2"></i> Escanear QR de Asistencia
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarEscaner"></button>
                </div>
                <div class="modal-body p-0 bg-black" style="position: relative; min-height: 300px;">
                    <video id="videoFeed"
                           style="width: 100%; display: block; transform: scaleX(1);"
                           autoplay
                           muted
                           playsinline>
                    </video>

                    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
                        width: 200px; height: 200px; border: 2px solid rgba(255,255,255,0.5);
                        border-radius: 15px; box-shadow: 0 0 0 4000px rgba(0,0,0,0.3);">
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <div class="w-100 text-center">
                        <p class="small text-muted mb-2">Asegurate de que el código esté bien iluminado</p>
                        <button class="btn btn-outline-danger w-100" @onclick="CerrarEscaner">
                            Cancelar y Volver
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    bool mostrarDialog = false;
    string mensajeTurno = "";
    string mensajeTabla = "";
    bool mostrarEscanner = false;
    bool jsListo = false;
    List<Reserva>? reservas = new List<Reserva>();
    bool mostrarInscriptos = false;
    bool mostrarDisponibles = false;
    bool quiereAgregar = false;
    string mensaje = "";
    Datos t = new Datos();
    private int turnoActualId;

    private int filtroActividadId = 0;
    private int filtroCanchaId = 0;
    private int filtroProfesorId = 0;
    private DateTime? filtroFecha;
    private int idAEliminar;
    private List<Profesor> todosLosProfesores = new();
    private List<Cancha> todasLasCanchas = new();
    private List<Profesor> profesoresDispo = new();
    private List<Actividad> actividades = new();
    private List<Cancha> canchasDispo = new();
    private List<Turno> turnos = new();
    private List<Turno> turnosFiltrados = new();
    bool mostrarDialogCancelar = false;

    void ConfirmarCancelacion(int Id) { idAEliminar = Id; mostrarDialogCancelar = true; }
    void ConfirmarEliminacion(int Id) { idAEliminar = Id; mostrarDialog = true; }

    Cancha? canchaSeleccionada => canchasDispo.FirstOrDefault(c => c.Id == t.Id_Cancha);

    private int horaSeleccionada
    {
        get => t.HoraInicio.Hour;
        set => t.HoraInicio = new TimeOnly(value, 0);
    }

    protected override async Task OnInitializedAsync()
    {
        turnos = (await ListarTurnosUseCase.Ejecutar(null, null, null, null, null)).ToList();
        actividades = (await ListarActividadesUseCase.ejecutar()).ToList();
        todosLosProfesores = (await ListarProfesoresUseCase.ejecutar()).ToList();
        todasLasCanchas = (await ListarCanchasUseCase.ejecutar()).ToList();
        turnosFiltrados = turnos;
    }

    private void AplicarFiltros()
    {
        turnosFiltrados = turnos.Where(tu =>
            (filtroActividadId == 0 || tu.Id_Actividad == filtroActividadId) &&
            (filtroCanchaId == 0 || tu.Id_Cancha == filtroCanchaId) &&
            (filtroProfesorId == 0 || tu.Id_Profesor == filtroProfesorId) &&
            (!filtroFecha.HasValue || tu.Fecha == DateOnly.FromDateTime(filtroFecha.Value))
        ).ToList();
    }

    private void LimpiarFiltros()
    {
        filtroActividadId = 0;
        filtroCanchaId = 0;
        filtroProfesorId = 0;
        filtroFecha = null;
        turnosFiltrados = turnos;
    }

    void CerrarSesion()
    {
        UsuarioSesion.CerrarSesion(); UsuarioSesion.NotificarCambio(); Navegador.NavigateTo("/Login", true);
    }

    void CrearTurno() => quiereAgregar = true;

    async Task RegistrarPago(int idReserva)
    {
        try
        {
            mensajeTabla = "";

            await ConfirmarPagoReservaUseCase.Ejecutar(idReserva);

            await RecargarReservas();

            mensajeTabla = "Pago confirmado con éxito.";
        }
        catch (Exception ex)
        {
            mensajeTabla = ex.Message;
        }
    }

    async Task MostrarInscriptos(int Id)
    {
        try
        {
            turnoActualId = Id;

            mostrarInscriptos = true;

            reservas = (await ListarInscriptosUseCase.Ejecutar(Id))?.ToList()
                       ?? new List<Reserva>();

            if (!reservas.Any())
            {
                mensajeTabla = "El turno no posee inscriptos";
            }
            else
            {
                mensajeTabla = "";
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            mensajeTabla = ex.Message;
            mostrarInscriptos = false;
        }
    }

    private async Task RecargarReservas()
    {
        reservas = (await ListarInscriptosUseCase.Ejecutar(turnoActualId))?.ToList()
                   ?? new List<Reserva>();

        await InvokeAsync(StateHasChanged);
    }

    async Task RegistrarAsistencia(int idReserva)
    {
        try
        {
            mensajeTabla = "";

            await RegistrarAsistenciaManualUseCase.Ejecutar(idReserva);

            await RecargarReservas();

            mensajeTabla = "Asistencia registrada con éxito.";
        }
        catch (Exception ex)
        {
            mensajeTabla = ex.Message;
        }
    }

    async Task BuscarPorDisponibilidad()
    {
        try
        {
            mensajeTurno = "";
            var horaMinima = new TimeOnly(18, 0); // 18:00
            var horaMaxima = new TimeOnly(23, 0); // 23:00

            if (t.HoraInicio < horaMinima || t.HoraInicio > horaMaxima)
            {
                mensajeTurno = "Error: El centro deportivo opera únicamente en el horario de 18:00 a 23:00 hs.";
                mostrarDisponibles = false;
                return;
            }

            if (t.Fecha == DateOnly.FromDateTime(DateTime.Now) && t.HoraInicio < TimeOnly.FromDateTime(DateTime.Now))
            {
                mensajeTurno = "Error: La hora seleccionada ya transcurrió.";
                mostrarDisponibles = false;
                return;
            }

            var (profesD, canchasD) = await ConsultarDisponibilidadUseCase.ejecutar(t.Fecha, t.HoraInicio);
            profesoresDispo = profesD.ToList();
            canchasDispo = canchasD.ToList();
            mostrarDisponibles = true;
        }
        catch (Exception ex)
        {
            mensajeTurno = ex.Message;
            mostrarDisponibles = false;
        }
    }

    async Task Aceptar()
    {
        try
        {
            mensajeTurno = "";
            var nuevoTurno = new Turno
            {
                Fecha = this.t.Fecha,
                HoraInicio = this.t.HoraInicio,
                HoraFin = this.t.HoraInicio.AddHours(1),
                CupoMaximo = this.t.CupoMaximo,
                Id_Actividad = this.t.Id_Actividad,
                Id_Profesor = this.t.Id_Profesor,
                Id_Cancha = this.t.Id_Cancha
            };
            await CrearTurnoUseCase.ejecutar(nuevoTurno);
            turnos = (await ListarTurnosUseCase.Ejecutar(null, null, null, null, null)).ToList();
            t = new Datos();
            StateHasChanged();
            AplicarFiltros();
            mensajeTurno = "El turno se ha creado exitosamente.";
            mostrarDisponibles = false;
        }
        catch (Exception ex) { mensajeTurno = ex.Message; }
    }



    private async Task AbrirEscaner()
    {
        mensaje = "";

        mostrarEscanner = true;

        await InvokeAsync(StateHasChanged);

        await Task.Delay(500);

        var dotNetRef = DotNetObjectReference.Create(this);

        bool exito = await JS.InvokeAsync<bool>(
            "escanearQR",
            "videoFeed",
            dotNetRef
        );

        if (!exito)
        {
            mensaje = "No se pudo acceder a la cámara";
            mostrarEscanner = false;
        }
    }


    bool procesandoQr = false;
    [JSInvokable]
    public async Task ProcesarQrDetectado(string codigoQr)
    {
        if (procesandoQr)
            return;

        procesandoQr = true;

        try
        {
            await RegistrarAsistenciaQrUseCase.Ejecutar(codigoQr);

            mensaje = "¡Asistencia registrada correctamente!";
        }
        catch (Exception ex)
        {
            mensaje = ex.Message;
        }

        await CerrarEscaner();

        procesandoQr = false;

        await InvokeAsync(StateHasChanged);
    }

    private async Task CerrarEscaner()
    {
        await JS.InvokeVoidAsync("detenerEscaner", "videoFeed");

        mostrarEscanner = false;

        await InvokeAsync(StateHasChanged);
    }

    void Cancelar()
    {
        mensajeTurno = "";
        quiereAgregar = false;
        mostrarDisponibles = false;
        t = new Datos();
    }

    public class Datos
    {
        public int Id { get; set; }
        public DateOnly Fecha { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public TimeOnly HoraInicio { get; set; } = new TimeOnly(18, 0);
        public int CupoMaximo { get; set; }
        public int Id_Actividad { get; set; }
        public int Id_Profesor { get; set; }
        public int Id_Cancha { get; set; }
    }

    private bool PuedeRegistrarAsistencia(Reserva r)
    {
        if (r?.Turno == null)
            return false;

        if (r.Estado != EstadoReserva.Confirmado)
            return false;

        if (r.Turno.Estado == EstadoTurno.Finalizado)
            return false;

        if (r.Asistencia != Asistencia.Ausente)
            return false;

        var fechaHoraInicio = r.Turno.Fecha.ToDateTime(r.Turno.HoraInicio);
        var fechaHoraFin = r.Turno.Fecha.ToDateTime(r.Turno.HoraFin);


        return DateTime.Now >= fechaHoraInicio.AddMinutes(-15) && DateTime.Now <= fechaHoraFin;
    }

    private bool yaPasoLaHora(Reserva r)
    {

        if (r?.Turno == null)
            return true;


        DateOnly fechaDelTurno = r.Turno.Fecha;
        TimeOnly horaInicioDelTurno = r.Turno.HoraInicio;


        DateOnly hoy = DateOnly.FromDateTime(DateTime.Now);
        TimeOnly ahora = TimeOnly.FromDateTime(DateTime.Now);

        if (fechaDelTurno < hoy)
            return true;


        if (fechaDelTurno == hoy && ahora > horaInicioDelTurno)
            return true;


        return false;
    }

    private async Task EliminarInscripto()
    {
        /*
        mensajeTabla = "";
        mostrarDialog = false;
        try
        {
            await EliminarInscriptoUseCase.Ejecutar(idAEliminar)
        }
        */
    }

    private void EditarTurno(int turnoId) => Navegador.NavigateTo($"/editar-turno/{turnoId}");

    private async Task CancelarTurno()
    {
        mensajeTurno ="";
        mostrarDialogCancelar = false;
        try {
            await CancelarTurnoUseCase.Ejecutar(idAEliminar);
            mensajeTurno = "El turno se ha cancelado exitosamente.";
            turnos = (await ListarTurnosUseCase.Ejecutar(null, null, null, null, null)).ToList();
            StateHasChanged();
        }
        catch (Exception ex){
            mensajeTurno = ex.Message;   
        }
    }

