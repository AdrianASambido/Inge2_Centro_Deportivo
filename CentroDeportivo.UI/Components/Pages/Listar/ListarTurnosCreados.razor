            @if (mostrarDialogCancelar)
            {
                <div class="modal show d-block shadow" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Confirmar cancelacion</h5>
                            </div>
                            <div class="modal-body">
                                <p>¿Estás seguro de que querés cancelar este turno?</p>
                            </div>
                            <div class="modal-footer">
                                <button class="btn btn-secondary" @onclick="() => mostrarDialogCancelar = false">Cancelar</button>
                                <button class="btn btn-danger" @onclick="() => CancelarTurno()">Confirmar</button>
