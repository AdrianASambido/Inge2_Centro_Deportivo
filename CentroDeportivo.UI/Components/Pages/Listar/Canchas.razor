@page "/canchas"
@rendermode InteractiveServer
@inject ListarCanchasUseCase ListarCanchasUseCase
@inject CrearCanchaUseCase CrearCanchaUseCase
@inject EliminarCanchaUseCase EliminarCanchaUseCase
@inject ICanchaRepositorio RepositorioCancha
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador

<PageTitle>Canchas</PageTitle>

@if (!(UsuarioSesion.EstaAutenticado() && (UsuarioSesion.esAdministrador() || UsuarioSesion.esEmpleado())))
{
    <div class="alert alert-warning">¡No tenés acceso a esta seccion!</div>
}
else
{
    <div class="container-fluid p-0">
        <h2 class="mb-1">Canchas</h2>
        <p class="text-muted mb-4">Bienvenido, @UsuarioSesion.UsuarioActual!.Nombre</p>

        <div class="d-flex gap-2 mb-4">
            <button class="btn btn-success" @onclick="CrearCancha">Crear cancha</button>
            <button class="btn btn-danger" @onclick="CerrarSesion">Cerrar sesión</button>
        </div>

        @if (quiereAgregar)
        {
            <div class="card shadow-sm mb-4 border-success" style="max-width: 400px;">
                <div class="card-body">
                    <h4 class="card-title mb-3">Nueva Cancha</h4>
                    <input placeholder="Número de cancha" @bind="can.numero" type="number" class="form-control mb-2" />
                    <input placeholder="Capacidad" @bind="can.capacidad" type="number" class="form-control mb-3" />
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary flex-grow-1" @onclick="Aceptar">Guardar</button>
                        <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </div>
            </div>
        }

        <div class="table-responsive shadow-sm" style="background: white; border-radius: 8px;">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Número</th>
                        <th>Capacidad</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in canchasFiltradas)
                    {
                        <tr>
                            <td>@c.Id</td>
                            <td class="fw-bold text-primary">Cancha @c.Numero</td>
                            <td>@c.Capacidad Personas</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-primary" @onclick="() => Editar(c.Id)">Editar</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => ConfirmarEliminacion(c.Id)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert alert-info mt-3">@mensaje</div>
}

@if (mostrarDialog)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow border-0">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">¿Eliminar cancha?</h5>
                </div>
                <div class="modal-body py-4">
                    <p class="mb-0">Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-light" @onclick="() => mostrarDialog = false">Cancelar</button>
                    <button class="btn btn-danger" @onclick="Eliminar">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    public Datos can = new Datos();
    string numeroBusquedaTexto = "";
    IEnumerable<Cancha> canchasFiltradas => string.IsNullOrWhiteSpace(numeroBusquedaTexto) ? cancha : cancha.Where(c => c.Numero.ToString().Contains(numeroBusquedaTexto));
    public bool quiereAgregar;
    string mensaje = "";
    bool mostrarDialog = false;
    int idAEliminar;
    List<Cancha> cancha = new List<Cancha>();

    protected override async Task OnInitializedAsync()
    {
        cancha = (await ListarCanchasUseCase.ejecutar()).ToList();
        if (cancha == null || !cancha.Any())
        {
            mensaje = "No hay canchas registradas.";
        }
    }
    void CerrarSesion() { UsuarioSesion.CerrarSesion(); UsuarioSesion.NotificarCambio(); Navegador.NavigateTo("/Login", true); }
    public void Editar(int Id) => Navegador.NavigateTo($"/editar-cancha/{Id}");
    void ConfirmarEliminacion(int Id) { idAEliminar = Id; mostrarDialog = true; }
    void CrearCancha() => quiereAgregar = true;

    async Task Eliminar()
    {
        mostrarDialog = false;
        try
        {
            await EliminarCanchaUseCase.ejecutar(idAEliminar);
            cancha = (await ListarCanchasUseCase.ejecutar()).ToList();
            mensaje = "Cancha eliminada.";
            StateHasChanged();
        }
        catch (Exception ex) { mensaje = ex.Message; }
    }

    async Task Aceptar()
    {
        try
        {
            var c = new Cancha(can.numero ?? 0, can.capacidad ?? 0);
            await CrearCanchaUseCase.ejecutar(c);
            cancha = (await ListarCanchasUseCase.ejecutar()).ToList();
            mensaje = "Cancha creada con exito."; 
            can = new Datos();
            quiereAgregar = false;
            mensaje = "";
            StateHasChanged();
        }
        catch (Exception ex) { mensaje = ex.Message; }
    }

    void Cancelar() { quiereAgregar = false; mensaje = ""; can = new Datos(); }
    public class Datos { public int? numero { get; set; } public int? capacidad { get; set; } }
}