@page "/registrar"
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador
@inject IHashServicio Hash

@rendermode InteractiveServer
@inject RegistrarUsuarioUseCase registrarUsuario

<PageTitle> Registro </PageTitle>

<h3>Registro de Usuario</h3>

<h6>Complete los datos</h6>

@if (!string.IsNullOrEmpty(mensaje))
{
    <p style="color: red">@mensaje</p>
}


<input placeholder="Nombre" @bind="usr.Nombre" class="form-control">
<input placeholder="Apellido" @bind="usr.Apellido" class="form-control">
<input placeholder="DNI" @bind="usr.DNI" class="form-control">
<input placeholder="Edad" @bind="usr.Edad" class="form-control">
<input placeholder="Domicilio" @bind="usr.Domicilio" class="form-control">
<input placeholder="Correo" @bind="usr.Correo" class="form-control">
<input placeholder="Contraseña" @bind="usr.Contrasenia" class="form-control" type="password">
<input placeholder="Repetir Contraseña" @bind="usr.Contrasenia2" class="form-control" type="password">

<button class="btn btn-primary" @onclick="Enviar">Registrar</button>
<button class="btn btn-danger" @onclick="Cancelar">Cancelar</button>

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert alert-danger">@mensaje</div>
}

@code {
    public string mensaje = "";
    public Datos usr = new();

    void MostrarMensaje(string msj)
    {
        mensaje = msj;
    }

    void Enviar()
    {

        if (usr.Contrasenia != usr.Contrasenia2)
        {
            mensaje = "Las contraseñas no coinciden.";
            return;
        }

        try
        {
            var usuario = new Usuario(usr.Nombre, usr.Apellido, usr.Domicilio, usr.DNI, usr.Contrasenia, usr.Correo, false, Rol.Cliente);
            
            registrarUsuario.Ejecutar(usuario);
            Navegador.NavigateTo("/usuarios");
        }
        catch (ValidacionExcepcion ex)
        {
            MostrarMensaje("Error de validación: " + ex.Message);
        }
        catch (DuplicadoExcepcion ex)
        {
            MostrarMensaje("Error de duplicado: " + ex.Message);
        }
    }

    void Cancelar()
    {
        Navegador.NavigateTo("/");
    }
    public class Datos
    {
        public string Nombre { get; set; } = "";
        public string Apellido { get; set; } = "";
        public int DNI { get; set; }
        public int Edad { get; set; } 
        public string Domicilio { get; set; } = "";
        public string Correo { get; set; } = "";
        public string Contrasenia { get; set; } = "";
        public string Contrasenia2 { get; set; } = "";
    }
    
}
