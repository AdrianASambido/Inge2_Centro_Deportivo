    private async Task FetchAsistenciaAsync()
    {
        var desde = DateOnly.FromDateTime(desdeDate);
        var hasta = DateOnly.FromDateTime(hastaDate);
        var indices = await ConsultarIndicesUsuarioUseCase.Ejecutar(idUsuario, desde, hasta);
        datosAsistencia = indices.Select(r => new AsistenciaDto
        {
            Actividad = r.NombreActividad,
            CantidadAsistencias = r.TotalAsistencias,
            CantidadCancelaciones = r.TotalCancelaciones
        }).ToList();

        actividadesCategories = datosAsistencia.Select(a => a.Actividad).ToList();
        asistenciasSeries = datosAsistencia.Select(a => a.CantidadAsistencias).ToList();
        cancelacionesSeries = datosAsistencia.Select(a => a.CantidadCancelaciones).ToList();
        StateHasChanged();
    }

    private async Task FetchHistorialAsync()
    {
        // Por ahora reutilizamos el mismo caso de uso de índices por usuario si no hay caso de uso específico
        await FetchAsistenciaAsync();
    }

    private void CambiarSeccion(string nuevaSeccion)
    {
        seccionActiva = nuevaSeccion;
        // actualizar rangos por defecto al cambiar sección
        desdeDate = DateTime.Today.AddMonths(-5);
        hastaDate = DateTime.Today;
    }

    // --- Clases de ejemplo (DTOs) para estructurar lo que recibe el gráfico ---
    public class IngresoPorMesDto
    {
        public string Mes { get; set; }
        public decimal MontoTotal { get; set; }
    }

    public class AsistenciaDto
    {
        public string Actividad { get; set; }
        public int CantidadAsistencias { get; set; }
        public int CantidadCancelaciones { get; set; }
    }

    // Colecciones planas usadas por ApexSeries/XAxis
    private List<decimal> ingresosValues = new();
    private List<string> ingresosCategories = new();

    private List<string> actividadesCategories = new();
    private List<int> asistenciasSeries = new();
    private List<int> cancelacionesSeries = new();
}

<style>
    /* Estilo para que todos los botones se vean siempre claros y definidos */
    .boton-menu {
        background-color: #f0f0f0; /* Un gris sutil para que se note el botón */
        color: #333 !important; /* Texto oscuro visible */
        margin-bottom: 10px; /* Separación entre botones */
        border: 1px solid #ddd;
        text-align: left; /* Alinea el texto a la izquierda */
        padding: 12px 15px;
        transition: transform 0.2s ease, background-color 0.2s ease; /* Transición suave para el efecto */
    }

        /* El botón seleccionado/activo mantiene el color destacado de Bootstrap */
        .boton-menu.active {
            background-color: #0d6efd !important; /* Azul de Bootstrap */
            color: white !important;
            border-color: #0d6efd;
        }

        /* EFECTO HOVER: Cuando pasás el mouse por arriba */
        .boton-menu:hover {
            background-color: #e2e8f0; /* Se oscurece un poquito el fondo */
            transform: scale(1.04); /* Agranda el botón un 4% de su tamaño */
            cursor: pointer;
        }

        /* Si pasás el mouse sobre el botón que YA está activo, que no pierda su fondo azul */
        .boton-menu.active:hover {
            background-color: #0b5ed7 !important;
        }

    .barra-lateral {
        border-right: 1px solid #dee2e6; /* Línea divisoria sutil con el panel derecho */
    }
</style>