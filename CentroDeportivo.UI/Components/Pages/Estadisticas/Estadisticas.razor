@page "/estadisticas"
@using CentroDeportivo.Aplicacion.Casos_de_uso.EstadisticaUseCase
@inject ConsultarIngresosDelNegocioUseCase ConsultarIngresosDelNegocioUseCase
@inject ConsultarIndicesUsuarioUseCase ConsultarIndicesUsuarioUseCase
@inject ConsultarIndicesActividadUseCase ConsultarIndicesActividadUseCase
@inject ConsultarIngresosActividadUseCase ConsultarIngresosActividadUseCase
@inject ConsultarHistorialUsuarioUseCase ConsultarHistorialUsuarioUseCase




<div class="container-fluid">
    <div class="row">
        <div class="col-md-3 bg-light min-vh-100 p-3 (barra-lateral)">
            <h4 class="mb-4 text-center">Estadísticas</h4>
            <div class="nav flex-column nav-pills">
                <button class="nav-link boton-menu @(seccionActiva == "ingresos" ? "active" : "")" @onclick='() => CambiarSeccion("ingresos")'>Ingresos Generales</button>
                <button class="nav-link boton-menu @(seccionActiva == "asistencia" ? "active" : "")" @onclick='() => CambiarSeccion("asistencia")'>Asistencia y Cancelaciones</button>
                <button class="nav-link boton-menu @(seccionActiva == "historialUsuario" ? "active" : "")" @onclick='() => CambiarSeccion("historialUsuario")'>Historial de Usuario</button>
                <button class="nav-link boton-menu @(seccionActiva == "indicesUsuario" ? "active" : "")" @onclick='() => CambiarSeccion("indicesUsuario")'>Indices usuario </button>
                <button class="nav-link boton-menu @(seccionActiva == "ingresoPorActividad" ? "active" : "")" @onclick='() => CambiarSeccion("ingresoPorActividad")'>Ingresos por actividad</button>
                <button class="nav-link boton-menu @(seccionActiva == "indicesActividad" ? "active" : "")" @onclick='() => CambiarSeccion("indicesActividad")'>Indices por actividad</button>
            </div>
        </div>

        <div class="col-md-9 p-4">
            @if (seccionActiva == "ingresos")
            {
                <div class="card p-3 shadow-sm">
                    <h5>Reporte de Ingresos del Negocio</h5>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label>Desde</label>
                            <input type="date" class="form-control" @bind="desdeDate" />
                        </div>
                        <div class="col-md-4">
                            <label>Hasta</label>
                            <input type="date" class="form-control" @bind="hastaDate" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button class="btn btn-primary" @onclick="FetchIngresosAsync">Buscar</button>
                        </div>
                    </div>

                    @if (datosIngresos == null || datosIngresos.Count == 0)
                    {
                        <p><em>No hay datos de ingresos para mostrar.</em></p>
                    }
                    else
                    {
                        @* 1. Gráfico: Ingresos mensuales usando series y categorías (evita lambdas en atributos) *@
                        <ApexChart TItem="decimal" Height="320" Title="Ingresos Mensuales ($)">
                            <ApexSeries TItem="decimal" Name="Ingresos" Items="ingresosValues" />
                            <ApexXAxis Categories="ingresosCategories" />
                        </ApexChart>
                    }
                </div>
            }
            else if (seccionActiva == "asistencia")
            {
                <div class="card p-3 shadow-sm">
                    <h5>Índices de Asistencia por Actividad</h5>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label>Desde</label>
                            <input type="date" class="form-control" @bind="desdeDate" />
                        </div>
                        <div class="col-md-4">
                            <label>Hasta</label>
                            <input type="date" class="form-control" @bind="hastaDate" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button class="btn btn-primary" @onclick="FetchAsistenciaAsync">Buscar</button>
                        </div>
                    </div>

                    @if (datosAsistencia == null || datosAsistencia.Count == 0)
                    {
                        <p><em>No hay datos de asistencia para mostrar.</em></p>
                    }
                    else
                    {
                        @* 2. Gráfico de barras: Asistencias vs Cancelaciones por actividad *@
                        <ApexChart TItem="int" Height="320" Title="Asistencias vs Cancelaciones">
                            <ApexSeries TItem="int" Name="Asistieron" Items="asistenciasSeries" />
                            <ApexSeries TItem="int" Name="Cancelaron" Items="cancelacionesSeries" />
                            <ApexXAxis Categories="actividadesCategories" />
                        </ApexChart>
                    }
                </div>
            }
            else if (seccionActiva == "historialUsuario")
            {
                <div class="card p-3 shadow-sm">
                    <h5>Consulta de Historial Personal</h5>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label>Desde</label>
                            <input type="date" class="form-control" @bind="desdeDate" />
                        </div>
                        <div class="col-md-4">
                            <label>Hasta</label>
                            <input type="date" class="form-control" @bind="hastaDate" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button class="btn btn-primary" @onclick="FetchHistorialAsync">Buscar</button>
                        </div>
                    </div>

                    @if (datosHistorial == null || datosHistorial.Count == 0)
                    {
                        <p><em>No hay datos de historial para mostrar.</em></p>
                    }
                    else
                    {
                        @* 3. Gráfico: Historial usuario*@
                        <ApexChart TItem="int" Height="320" Title="Asistencias vs Cancelaciones">
                            <ApexSeries TItem="int" Name="Asistieron" Items="asistenciasSeries" />
                            <ApexSeries TItem="int" Name="Cancelaron" Items="cancelacionesSeries" />
                            <ApexXAxis Categories="actividadesCategories" />
                        </ApexChart>
                    }
                </div>
            }                       //------------------------------ Desde acá corregir ------------------------------
            else if (seccionActiva == "indicesUsuario")
            {
                <div class="card p-3 shadow-sm">
                    <h5>Consulta de Historial Personal</h5>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label>Desde</label>
                            <input type="date" class="form-control" @bind="desdeDate" />
                        </div>
                        <div class="col-md-4">
                            <label>Hasta</label>
                            <input type="date" class="form-control" @bind="hastaDate" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button class="btn btn-primary" @onclick="FetchHistorialAsync">Buscar</button>
                        </div>
                    </div>

                    @if (datosIndicesUsuario == null || datosIndicesUsuario.Count == 0)
                    {
                        <p><em>No hay datos de historial para mostrar.</em></p>
                    }
                    else
                    {
                        @* 3. ARREGLAR ESTE --- Gráfico de barras: Asistencias vs Cancelaciones por actividad *@
                        <ApexChart TItem="int" Height="320" Title="Asistencias vs Cancelaciones">
                            <ApexSeries TItem="int" Name="Asistieron" Items="asistenciasSeries" />
                            <ApexSeries TItem="int" Name="Cancelaron" Items="cancelacionesSeries" />
                            <ApexXAxis Categories="actividadesCategories" />
                        </ApexChart>
                    }
                </div>
            }
            else if (seccionActiva == "ingresoPorActividad")
            {
                <div class="card p-3 shadow-sm">
                    <h5>Consulta de Historial Personal</h5>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label>Desde</label>
                            <input type="date" class="form-control" @bind="desdeDate" />
                        </div>
                        <div class="col-md-4">
                            <label>Hasta</label>
                            <input type="date" class="form-control" @bind="hastaDate" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button class="btn btn-primary" @onclick="FetchHistorialAsync">Buscar</button>
                        </div>
                    </div>

                    @if (datosIngresosActividad == null || datosIngresosActividad.Count == 0)
                    {
                        <p><em>No hay datos de historial para mostrar.</em></p>
                    }
                    else
                    {
                        @* 3. ARREGLAR ESTE --- Gráfico de barras: Asistencias vs Cancelaciones por actividad *@
                        <ApexChart TItem="int" Height="320" Title="Asistencias vs Cancelaciones">
                            <ApexSeries TItem="int" Name="Asistieron" Items="asistenciasSeries" />
                            <ApexSeries TItem="int" Name="Cancelaron" Items="cancelacionesSeries" />
                            <ApexXAxis Categories="actividadesCategories" />
                        </ApexChart>
                    }
                </div>
            }
            else if (seccionActiva == "indicesActividad")
            {
                <div class="card p-3 shadow-sm">
                    <h5>Consulta de Historial Personal</h5>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label>Desde</label>
                            <input type="date" class="form-control" @bind="desdeDate" />
                        </div>
                        <div class="col-md-4">
                            <label>Hasta</label>
                            <input type="date" class="form-control" @bind="hastaDate" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button class="btn btn-primary" @onclick="FetchHistorialAsync">Buscar</button>
                        </div>
                    </div>

                    @if (datosIndicesActividad == null || datosIndicesActividad.Count == 0)
                    {
                        <p><em>No hay datos de historial para mostrar.</em></p>
                    }
                    else
                    {
                        @* 3. ARREGLAR ESTE --- Gráfico de barras: Asistencias vs Cancelaciones por actividad *@
                        <ApexChart TItem="int" Height="320" Title="Asistencias vs Cancelaciones">
                            <ApexSeries TItem="int" Name="Asistieron" Items="asistenciasSeries" />
                            <ApexSeries TItem="int" Name="Cancelaron" Items="cancelacionesSeries" />
                            <ApexXAxis Categories="actividadesCategories" />
                        </ApexChart>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string seccionActiva = "ingresos";

    // Listas donde vamos a guardar los datos que devuelven los Casos de Uso
    private List<IngresoPorMesDto>? datosIngresos;
    private List<AsistenciaDto>? datosAsistencia;
    private List<AsistenciaDto>? datosHistorial;
    private List<AsistenciaDto>? datosIndicesUsuario;
    private List<IngresoPorMesDto>? datosIngresosActividad;
    private List<AsistenciaDto>? datosIndicesActividad;


    // Rango de búsqueda seleccionable por el usuario (usamos DateTime en inputs y convertimos a DateOnly)
    private DateTime desdeDate = DateTime.Today.AddMonths(-5);
    private DateTime hastaDate = DateTime.Today;
    private int idUsuario = 1; // cambiar según contexto/selección

    // EL CICLO DE VIDA: Aquí llamo a los Casos de Uso cuando la página arranca
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Iniciar con los últimos 6 meses
            await FetchIngresosAsync();
            await FetchAsistenciaAsync();
        }
        catch (Exception ex)
        {
            // Loguear la excepción para diagnóstico y devolver listas vacías
            Console.WriteLine($"ESTADISTICAS-ERROR: {ex.Message}\n{ex.StackTrace}");
            datosIngresos = new List<IngresoPorMesDto>();
            datosAsistencia = new List<AsistenciaDto>();
        }
    }

    // ----- Métodos para buscar según rango de fechas seleccionadas -----
    private async Task FetchIngresosAsync()
    {
        // 1. Validar fechas para evitar rangos imposibles
        if (hastaDate < desdeDate) return;

        var start = DateOnly.FromDateTime(new DateTime(desdeDate.Year, desdeDate.Month, 1));
        var endMonth = new DateTime(hastaDate.Year, hastaDate.Month, 1);

        // Calculamos de forma segura cuántos meses hay de diferencia
        int totalMeses = ((endMonth.Year - start.Year) * 12) + endMonth.Month - start.Month;

        // Si el rango es ridículamente largo, le ponemos un tope por seguridad
        if (totalMeses > 24) totalMeses = 24;

        // Generamos la lista de tareas para ejecutarlas en paralelo
        var tareas = new List<Task<IngresoPorMesDto>>();

        for (int i = 0; i <= totalMeses; i++)
        {
            var dt = new DateTime(start.Year, start.Month, 1).AddMonths(i);
            var mesStart = DateOnly.FromDateTime(dt);
            var mesEnd = mesStart.AddMonths(1).AddDays(-1);

            // Agregamos la Promesa (Task) a la lista sin esperarla todavía
            tareas.Add(Task.Run(async () =>
            {
                var total = await ConsultarIngresosDelNegocioUseCase.Ejecutar(mesStart, mesEnd);
                return new IngresoPorMesDto
                {
                    Mes = mesStart.ToString("MMM yyyy"),
                    MontoTotal = total
                };
            }));
        }

        // 🔥 LA MAGIA: Ejecuta TODAS las consultas a la DB al mismo tiempo
        var resultados = await Task.WhenAll(tareas);

        // Ordenamos cronológicamente y asignamos a la lista del gráfico
        datosIngresos = resultados.OrderBy(r => DateTime.Parse(r.Mes)).ToList();

        // Le avisamos a Blazor que refresque la pantalla con los datos nuevos
        StateHasChanged();
    }




