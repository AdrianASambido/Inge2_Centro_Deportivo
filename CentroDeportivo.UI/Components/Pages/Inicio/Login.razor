@page "/Login"
@layout PublicLayout
@inject IniciarSesionUseCase IniciarSesionUseCase
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador
@inject IUsuarioRepositorio UsuarioRepositorio
@rendermode InteractiveServer

<PageTitle>Iniciar Sesión</PageTitle>

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow p-4" style="width: 100%; max-width: 400px;">
        <h2 class="text-center mb-4">Iniciar Sesión</h2>
     
        <div class="mb-3">
            <label class="form-label">Correo Electrónico</label>
            <input placeholder="ejemplo@correo.com" @bind="datos.Correo" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Contraseña</label>
            <input placeholder="••••••••" @bind="datos.Password" class="form-control" type="password" />
        </div>

        <div class="d-grid gap-2 mb-3">
            <button class="btn btn-primary" @onclick="IniciarSesion">Confirmar</button>
            <button class="btn btn-outline-primary" @onclick="Registrarse">Registrarme</button>
        </div>

        <div class="text-center">
            <NavLink href="/olvide-contrasenia" class="text-decoration-none">
                ¿Olvidaste tu contraseña?
            </NavLink>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger mt-3 text-center">@error</div>
        }
    </div>
</div>

@code {
    public DatosLogin datos = new();
    public string error = "";

    public async Task IniciarSesion()
    {
        error = "";
        try
        {
            var usuario = await IniciarSesionUseCase.ejecutar(datos.Correo, datos.Password);
            UsuarioSesion.IniciarSesion(usuario);

            if (UsuarioSesion.esAdministrador() || UsuarioSesion.esEmpleado())
            {
                Navegador.NavigateTo("/listar-turnos-creados");
            }
            else
            {
                Navegador.NavigateTo("/Turnos");
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    void Registrarse() => Navegador.NavigateTo("/registrar");

    public class DatosLogin
    {
        public string Correo { get; set; } = "";
        public string Password { get; set; } = "";
    }
}