@page "/Login"
@inject IniciarSesionUseCase IniciarSesionUseCase
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador
@inject IUsuarioRepositorio UsuarioRepositorio
@rendermode InteractiveServer

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6 col-lg-5">

            <div class="card shadow p-4">

                <h2 class="mb-3">Iniciar sesion</h2>
     
                    <div class="mb-3">
                        <input placeholder="Correo" @bind="datos.Correo" class="form-control mb-3" />
                    </div>

                    <div class="mb-3">
                        <input placeholder="Contraseña" @bind="datos.Password" class="form-control mb-3" type="password" />
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="IniciarSesion">Confirmar</button>
                        <button class="btn btn-danger" @onclick="Registrarse">Registrarme</button>
                        <NavLink href="/olvide-contrasenia" class="text-primary">
                            ¿Olvidaste tu contraseña?
                        </NavLink>
                    </div>

                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="alert alert-danger">@error</div>
                    }
                </div>
            </div>
        </div>
    </div>


@code {
    public DatosLogin datos = new();
    public string error = "";

    public async Task IniciarSesion()
    {
        error = "";

        try
        {
            var usuario = await IniciarSesionUseCase.ejecutar(datos.Correo, datos.Password);

            UsuarioSesion.IniciarSesion(usuario);

            Navegador.NavigateTo("/Actividades");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    void Registrarse()
    {
        Navegador.NavigateTo("/registrar");
    }

    public class DatosLogin
    {
        public string Correo { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
