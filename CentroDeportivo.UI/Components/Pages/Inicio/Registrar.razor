@page "/registrar"
@inject IUsuarioRepositorio UsuarioRepositorio
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador
@inject IHashServicio Hash
@rendermode InteractiveServer
@inject RegistrarUsuarioUseCase agregarUsuario

<PageTitle> Registro </PageTitle>

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6 col-lg-5">

            <div class="card shadow p-4">

                <h3 class="mb-3">Registro de Usuario</h3>

                <h5 class="mb-4 text-muted">Complete los datos</h5>

                    <input placeholder="Nombre" @bind="usr.Nombre" class="form-control mb-3">
                    <input placeholder="Apellido" @bind="usr.Apellido" class="form-control mb-3">
                    <input placeholder="DNI" @bind="usr.DNI" class="form-control mb-3">
                    <input placeholder="Edad" @bind="usr.Edad" class="form-control mb-3">
                    <input placeholder="Domicilio" @bind="usr.Domicilio" class="form-control mb-3">
                    <input placeholder="Correo" @bind="usr.Correo" class="form-control mb-3">
                    <input placeholder="Contraseña" @bind="usr.Contrasenia" class="form-control mb-3" type="password">
                    <input placeholder="Repetir Contraseña" @bind="usr.Contrasenia2" class="form-control mb-3" type="password">
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="Enviar">Registrar</button>
                        <button class="btn btn-danger" @onclick="Cancelar">Cancelar</button>
                    </div>

                    @if (!string.IsNullOrEmpty(mensaje))
                    {
                        <div class="alert alert-danger">@mensaje</div>
                    }

            </div>

        </div>

    </div>

</div>

@code {
    public string mensaje = "";
    public Datos usr = new();

    void MostrarMensaje(string msj)
    {
        mensaje = msj;
    }

    async Task Enviar()
    {

        if (usr.Contrasenia != usr.Contrasenia2)
        {
            mensaje = "Las contraseñas no coinciden.";
            return;
        }

        try
        {
            var usuario = new Usuario(usr.Nombre, usr.Apellido, string.Empty, string.Empty, usr.Contrasenia, usr.Correo, false, Rol.Cliente);
            
            await agregarUsuario.ejecutar(usuario);
            Navegador.NavigateTo("/Login");
        }
        catch (Exception ex)
        {
            MostrarMensaje("Error de validación: " + ex.Message);

        }
    }

    void Cancelar()
    {
        Navegador.NavigateTo("/");
    }
    public class Datos
    {
        public string Nombre { get; set; } = "";
        public string Apellido { get; set; } = "";
        public string DNI { get; set; }
        public int Edad { get; set; } 
        public string Domicilio { get; set; } = "";
        public string Correo { get; set; } = "";
        public string Contrasenia { get; set; } = "";
        public string Contrasenia2 { get; set; } = "";
    }
    
}
