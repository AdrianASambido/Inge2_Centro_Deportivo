@page "/registrar"
@layout PublicLayout
@inject IUsuarioRepositorio UsuarioRepositorio
@inject Sesion UsuarioSesion
@inject NavigationManager Navegador
@inject IHashServicio Hash
@rendermode InteractiveServer
@inject RegistrarUsuarioUseCase agregarUsuario

<PageTitle>Registro</PageTitle>

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow p-4" style="width: 100%; max-width: 450px;">
        <h3 class="text-center mb-1">Registro de Usuario</h3>
        <p class="text-muted text-center mb-4">Complete sus datos personales</p>

        <div class="mb-2">
            <input placeholder="Nombre" @bind="usr.Nombre" type="text" class="form-control">
        </div>
        <div class="mb-2">
            <input placeholder="Apellido" @bind="usr.Apellido" text="text" class="form-control">
        </div>
        <div class="mb-2">
            <input placeholder="DNI" @bind="usr.DNI" type="number" class="form-control">
        </div>
        <div class="mb-2">
            <input placeholder="Edad" @bind="usr.Edad" type="number" class="form-control">
        </div>
        <div class="mb-2">
            <input placeholder="Domicilio" @bind="usr.Domicilio" class="form-control">
        </div>
        <div class="mb-2">
            <input placeholder="Correo" @bind="usr.Correo" type="email" class="form-control" autocomplete="new-email">
        </div>
        <div class="mb-2">
            <input placeholder="Contraseña" @bind="usr.Contrasenia" class="form-control" type="password" autocomplete="new-password">
        </div>

        <div class="d-grid gap-2">
            <button class="btn btn-primary" @onclick="Enviar">Registrar</button>
            <button class="btn btn-outline-secondary" @onclick="Cancelar">Cancelar</button>
        </div>

        @if (!string.IsNullOrEmpty(mensaje))
        {
            <div class="alert alert-danger mt-3 mb-0 text-center">@mensaje</div>
        }
    </div>
</div>

@code {
    public string mensaje = "";
    public Datos usr = new();

    void MostrarMensaje(string msj) => mensaje = msj;

    async Task Enviar()
    {
        try
        {
            var usuario = new Usuario(usr.Nombre, usr.Apellido, usr.Domicilio, usr.DNI, usr.Contrasenia, usr.Correo, false, Rol.Cliente);
            await agregarUsuario.ejecutar(usuario);
            Navegador.NavigateTo("/Login");
        }
        catch (Exception ex)
        {
            MostrarMensaje("Error: " + ex.Message);
        }
    }

    void Cancelar() => Navegador.NavigateTo("/");

    public class Datos
    {
        public string Nombre { get; set; } = "";
        public string Apellido { get; set; } = "";
        public string DNI { get; set; } = "";
        public int? Edad { get; set; }
        public string Domicilio { get; set; } = "";
        public string Correo { get; set; } = "";
        public string Contrasenia { get; set; } = "";
    }
}